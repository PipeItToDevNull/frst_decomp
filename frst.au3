FUNC WHITELISTREG ( )
    FOR $I = 0x1 TO UBOUND ( $ARRAYREG ) + 0xffffffff
        SELECT
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\Software\\...\\Winlogon\\GPExtensions: \[{8472C2C4-6B70-4301-A20D-A6CEA5F82B7E}\] -> " & $C & "\\WINDOWS\\system32\\StartTileData\.dll \[.+\] \(Microsoft.+-> Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\Software\\...\\Winlogon\\GPExtensions: \[{9F02E2F5-5A41-4D1A-B473-4617E84BC957}\] -> " & $C & "\\WINDOWS\\system32\\WindowsProtectedPrintConfiguration\.dll \[.+\] \(Microsoft.+-> Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\...\\Print\\Monitors\\Virtual Port Monitor: " & $C & "\\WINDOWS\\system32\\VirtualMon.dll \[.+\] \(Microsoft.+-> Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM(|-x32)\\...\\Winlogon: \[Userinit\] " & $C & "\\WINDOWS\\(system32|sysWOW64)\\userinit\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\...\\Run: \[(HotKeysCmds|IgfxTray|Persistence)\] => [C-Z]:\\WINDOWS\\system32\\(igfxtray|hkcmd|igfxpers)\.exe \[.+\] \(Intel.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[Sidebar\] => .+\\Windows Sidebar\\Sidebar\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[Teams\] => .+\\Local\\Microsoft\\WindowsApps\\MSTeams_8wekyb3d8bbwe\\ms-teams.exe \[0 0\] \(\) \[symlink -> \]" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[Speech Recognition\] => .+\\WINDOWS\\Speech\\Common\\sapisvr.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\RunOnce: \[WAB Migrate\] => .+\\Program Files\\Windows Mail\\wab\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\.+\\Run: \[SecurityHealth\] => [C-Z]:\\WINDOWS\\system32\\SecurityHealthSystray\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[WindowsWelcomeCenter\] => rundll32.exe oobefldr.dll,ShowWelcomeCenter" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\SCRNSAVE.EXE -> .:\\WINDOWS\\(system32|SysWOW64)\\logon.scr \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[OneDriveSetup\] => .+\\Windows\\(system32|SysWOW64)\\OneDriveSetup\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKU\\.+\\Run: \[OneDrive\] => .+\\Users\\.+?\\AppData\\Local\\Microsoft\\OneDrive\\OneDrive.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM(|-x32)\\...\\Winlogon: \[Shell\] " & $C & "\\Windows(|\\SysWOW64)\\Explorer\.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM(|-x32)\\...\\Winlogon: \[UIHost\] " & $C & "\\WINDOWS(|\\SysWOW64)\\system32\\logonui.exe \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)HKLM\\...\\Providers\\(Internet Print Provider|LanMan Print Services): .:\\Windows\\system32\\(inetpp|win32spl).dll \[.+\] \(Microsoft.+\)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)(HKLM|HKU)\\.+\\Policies\\Explorer: \[(NoDriveTypeAutoRun|NoDriveAutoRun)\] \d+" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)(HKLM|HKU)\\.+\\Policies\\Explorer: \[(NoSimpleNetIDList|ClearRecentDocsOnExit|NoResolveTrack|BindDirectlyToPropertySetStorage|HonorAutoRunSetting|NoActiveDesktop|NoActiveDesktopChanges)\] (1|0)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)(HKLM|HKU)\\.+\\Policies\\Explorer: \[(ForceActiveDesktopOn|NoRecentDocsHistory|NoLowDiskSpaceChecks|NoSMHelp|StartMenuLogoff|NoFileAssociate|NoPropertiesMyComputer|NoRun|NoClose|NoDrives|NoCDBurning|NoFolderOptions|NoControlPanel)\] 0" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)Lsa: \[Authentication Packages\] msv1_0(| SshdPinAuthLsa)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)Lsa: \[Notification Packages\] (rassfm |)scecli( rassfm|)" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)SecurityProviders: credssp.dll" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)IFEO\\svchost.exe: \[MinimumStackCommitInBytes\] 32768" )
        CASE STRINGREGEXP ( $ARRAYREG [ $I ] , "(?i)(HKLM|HKU)\\.+\[(DisableTaskMgr|DisableRegistryTools|NoDesktop|DisableRegedit|DisableCMD)\] 0" )
