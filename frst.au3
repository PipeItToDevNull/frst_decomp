    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , $VRESULT )
    IF BITAND ( $IFLAGS , 0x200 ) THEN
        RETURN __WINAPI_PARSEMULTISELECTFILEDIALOGPATH ( $VRESULT )
    ELSE
        RETURN __WINAPI_PARSEFILEDIALOGPATH ( $VRESULT )
    ENDIF
ENDFUNC
