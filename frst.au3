FUNC __ENUMRESNAMESPROC ( $HMODULE , $ITYPE , $INAME , $LPARAM )
    #forceref $hModule, $iType, $lParam
    LOCAL $ILENGTH = _WINAPI_STRLEN ( $INAME )
    __INC ( $__G_VENUM )
    IF $ILENGTH THEN
        $__G_VENUM [ $__G_VENUM [ 0x0 ] ] = DLLSTRUCTGETDATA ( DLLSTRUCTCREATE ( "wchar[" & ( $ILENGTH + 0x1 ) & "]" , $INAME ) , 0x1 )
