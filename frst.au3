    LOCAL $ACALL = DLLCALL ( "user32.dll" , "uint" , "GetRegisteredRawInputDevices" , "struct*" , $PBUFFER , "uint*" , FLOOR ( $ILENGTH / $ILENGTHRAW ) , "uint" , $ILENGTHRAW )
