    SWITCH $ACALL [ 0x0 ]
        CASE 0x0
        CASE 0x523
        IF STRINGSTRIPWS ( $SUSER , 0x1 + 0x2 ) THEN
            $ACALL [ 0x2 ] = $SUSER
            $ACALL [ 0x4 ] = ""
        ELSE
            CONTINUECASE
        ENDIF
        CASE ELSE
        RETURN SETERROR ( 0xa , $ACALL [ 0x0 ] , 0x0 )
    ENDSWITCH
    LOCAL $ARET [ 0x2 ]
    $ARET [ 0x0 ] = $ACALL [ 0x4 ]
    $ARET [ 0x1 ] = $ACALL [ 0x2 ]
    RETURN $ARET
