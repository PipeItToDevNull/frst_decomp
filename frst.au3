    IF $ACALL [ 0x0 ] THEN RETURN SETERROR ( 0xa , $ACALL [ 0x0 ] , 0x0 )
    SWITCH $IATTRIBUTE
        CASE 0x1 , 0xe
        RETURN DLLSTRUCTGETDATA ( $TDATA , 0x1 )
        CASE ELSE
        RETURN $TDATA
    ENDSWITCH
ENDFUNC
