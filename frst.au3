    DLLSTRUCTSETDATA ( $TXFORM , 0x4 , $NM22 )
    DLLSTRUCTSETDATA ( $TXFORM , 0x5 , $NDX )
    DLLSTRUCTSETDATA ( $TXFORM , 0x6 , $NDY )
    RETURN $TXFORM
ENDFUNC
