    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "handle" , "GetModuleHandleW" , "wstr" , $SMODULENAME )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
