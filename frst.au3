    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    $AINFO [ 0x0 ] = $ACALL [ 0x1 ]
    $AINFO [ 0x1 ] = $ACALL [ 0x2 ]
    $AINFO [ 0x2 ] = $ACALL [ 0x3 ] <> 0x0
    RETURN SETEXTENDED ( $ACALL [ 0x0 ] , $AINFO )
