    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "QueryPerformanceFrequency" , "int64*" , 0x0 )
    IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0xa , @EXTENDED , 0x0 )
    RETURN $ACALL [ 0x1 ]
ENDFUNC
FUNC _WINAPI_QUERYPROCESSCYCLETIME ( $IPID = 0x0 )
    IF NOT $IPID THEN $IPID = @AUTOITPID
    LOCAL $HPROCESS = DLLCALL ( "kernel32.dll" , "handle" , "OpenProcess" , "dword" , __CONVPROCESDESIREDACCESS ( ) , "bool" , 0x0 , "dword" , $IPID )
    IF @ERROR OR NOT $HPROCESS [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0x14 , @EXTENDED , 0x0 )
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "QueryProcessCycleTime" , "handle" , $HPROCESS [ 0x0 ] , "uint64*" , 0x0 )
    IF __CHECKERRORCLOSEHANDLE ( $ACALL , $HPROCESS [ 0x0 ] ) THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    RETURN $ACALL [ 0x2 ]
ENDFUNC
FUNC _WINAPI_QUERYPROCESSORUSAGE ( $BTOOLTIP = FALSE )
    STATIC LOCAL $FFREQUENCY = 1 / DLLCALL ( "kernel32.dll" , "bool" , "QueryPerformanceFrequency" , "uint64*" , 0x0 ) [ 0x1 ]
    STATIC LOCAL $ICURTOTALTICKCOUNT = 0x0
    STATIC LOCAL $ICURTICKCOUNT = DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ]
    LOCAL $APROCESSES = PROCESSLIST ( )
    LOCAL $ITOTALTICKCOUNT = 0x0
    FOR $I = 0x1 TO $APROCESSES [ 0x0 ] [ 0x0 ]
        IF $APROCESSES [ $I ] [ 0x0 ] = "taskmgr.exe" OR $APROCESSES [ $I ] [ 0x0 ] = "dwm.exe" THEN CONTINUELOOP
        IF $APROCESSES [ $I ] [ 0x1 ] = @AUTOITPID OR $APROCESSES [ $I ] [ 0x1 ] = 0x4 THEN CONTINUELOOP
        $ITOTALTICKCOUNT += _WINAPI_QUERYPROCESSCYCLETIME ( $APROCESSES [ $I ] [ 0x1 ] )
    NEXT
    LOCAL $IDIFFTOTALTICKCOUNT = $ITOTALTICKCOUNT - $ICURTOTALTICKCOUNT
    LOCAL $IDIFFTICKCOUNT = DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ] - $ICURTICKCOUNT
    $ICURTICKCOUNT = DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ]
    IF $ICURTOTALTICKCOUNT = 0x0 THEN
        $ICURTOTALTICKCOUNT = $ITOTALTICKCOUNT
        RETURN _WINAPI_QUERYPROCESSORUSAGE ( FALSE )
    ENDIF
    $ICURTOTALTICKCOUNT = $ITOTALTICKCOUNT
    LOCAL $FPERCENT = ROUND ( $IDIFFTOTALTICKCOUNT / $IDIFFTICKCOUNT * $FFREQUENCY * 0x64 , 0x1 )
    IF $BTOOLTIP AND $FPERCENT > 0x0 THEN TOOLTIP ( "CPU " & $FPERCENT & "%" , DEFAULT , DEFAULT , "" , 0x0 , 0x1 )
    RETURN $FPERCENT
ENDFUNC
