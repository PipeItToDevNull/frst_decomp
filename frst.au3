        IF UBOUND ( $APATHS , 0x2 ) THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    ELSE
        DIM $APATHS [ 0x1 ] = [ $IPATH ]
    ENDIF
    FOR $I = 0x0 TO UBOUND ( $APATHS ) + 0xffffffff
        IF NOT _WINAPI_PATHISDIRECTORY ( $APATHS [ $I ] ) THEN RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
