FUNC _WINAPI_CREATEPROCESSWITHTOKEN ( $SAPP , $SCMD , $IFLAGS , $TSTARTUPINFO , $TPROCESSINFO , $HTOKEN , $ILOGON = 0x0 , $PENVIRONMENT = 0x0 , $SDIR = "" )
    IF NOT STRINGSTRIPWS ( $SAPP , 0x1 + 0x2 ) THEN $SAPP = NULL
