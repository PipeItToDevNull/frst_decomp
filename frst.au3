FUNC _WINAPI_PARSEUSERNAME ( $SUSER )
    IF NOT __DLL ( "credui.dll" ) THEN RETURN SETERROR ( 0x67 , 0x0 , 0x0 )
    LOCAL $ACALL = DLLCALL ( "credui.dll" , "dword" , "CredUIParseUserNameW" , "wstr" , $SUSER , "wstr" , "" , "ulong" , 0x1000 , "wstr" , "" , "ulong" , 0x1000 )
