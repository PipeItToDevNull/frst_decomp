        $NAME = "Malwarebytes Corporation"
        CASE "D37F61D57CB0481F3D77EDAC7DE72196C4314E2C" , "775B373B33B9D15B58BC02B184704332B97C3CAF" , "88AD5DFE24126872B33175D1778687B642323ACF"
        $NAME = "McAfee"
