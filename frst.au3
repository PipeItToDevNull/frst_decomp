    $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "SetLocalTime" , "struct*" , $TSYSTEMTIME )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , FALSE )
