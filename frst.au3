    LOCAL $AVOS = DLLCALL ( "advapi32.dll" , "ptr" , "OpenServiceW" , "ptr" , $HSC , "wstr" , $SSERVICENAME , "dword" , $IACCESS )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    RETURN $AVOS [ 0x0 ]
ENDFUNC
FUNC QUERYSERVICECONFIG ( $HSERVICE , $PSERVICECONFIG , $IBUFSIZE )
    LOCAL $AVQSC = DLLCALL ( "advapi32.dll" , "int" , "QueryServiceConfigW" , "ptr" , $HSERVICE , "ptr" , $PSERVICECONFIG , "dword" , $IBUFSIZE , "dword*" , 0x0 )
    RETURN $AVQSC
ENDFUNC
GLOBAL CONST $HZIPFLDR_DLL = DLLOPEN ( "zipfldr.dll" )
GLOBAL CONST $CLSID_CZIPFOLDER = "{e88dcce0-b7b3-11d1-a9f0-00aa0060fa31}"
GLOBAL CONST $SIID_ICLASSFACTORY = "{00000001-0000-0000-C000-000000000046}"
GLOBAL CONST $TAGICLASSFACTORY = "CreateInstance hresult(ptr;clsid;ptr*);" & "LockServer hresult(bool);"
GLOBAL $TAGIPERSIST = "GetClassID hresult(ptr*);"
GLOBAL CONST $SIID_IPERSISTFILE = "{0000010b-0000-0000-C000-000000000046}"
GLOBAL $TAGIPERSISTFILE = $TAGIPERSIST & "IsDirty hresult();" & "Load hresult(wstr;dword);" & "Save hresult(wstr;bool);" & "SaveCompleted hresult(wstr);" & "GetCurFile hresult(ptr*);"
GLOBAL CONST $SIID_IPERSISTFOLDER = "{000214EA-0000-0000-C000-000000000046}"
GLOBAL $TAGIPERSISTFOLDER = $TAGIPERSIST & "Initialize hresult(ptr);"
GLOBAL CONST $SIID_ISHELLFOLDER = "{000214E6-0000-0000-C000-000000000046}"
GLOBAL $TAGISHELLFOLDER = "ParseDisplayName hresult(hwnd;ptr;wstr;ulong*;ptr*;ulong*);" & "EnumObjects hresult(hwnd;dword;ptr*);" & "BindToObject hresult(struct*;ptr;clsid;ptr*);" & "BindToStorage hresult(struct*;ptr;clsid;ptr*);" & "CompareIDs hresult(lparam;struct*;struct*);" & "CreateViewObject hresult(hwnd;clsid;ptr*);" & "GetAttributesOf hresult(uint:struct*;ulong*);" & "GetUIObjectOf hresult(hwnd;uint;struct*;clsid;uint*;ptr*);" & "GetDisplayNameOf hresult(struct*;dword;struct*);" & "SetNameOf hresult(hwnd;struct*;wstr;dword;struct*);"
GLOBAL CONST $TAGISEQUENTIALSTREAM = "Read hresult(struct*;dword;dword*);" & "Write hresult(struct*;dword;dword*);"
GLOBAL CONST $SIID_ISTREAM = "{0000000c-0000-0000-C000-000000000046}"
GLOBAL CONST $TAGISTREAM = $TAGISEQUENTIALSTREAM & "Seek hresult(int64;dword;uint64*);" & "SetSize hresult(uint64);" & "CopyTo hresult(ptr;uint64;uint64*;uint64*);" & "Commit hresult(dword);" & "Revert hresult();" & "LockRegion hresult(uint64;uint64;dword);" & "UnlockRegion hresult(uint64;uint64;dword);" & "Stat hresult(struct*;dword);" & "Clone hresult(ptr*);"
FUNC UNZIP_SAVEFILETOBINARYONCE ( $SZIP , $SFILE , $IWANTEDSIZE = DEFAULT )
    LOCAL $OSHELLFOLDER , $OPERSISTF
    LOCAL $BRET = UNZIP_SAVEFILETOBINARY ( $SZIP , $SFILE , $OSHELLFOLDER , $OPERSISTF , $IWANTEDSIZE )
    LOCAL $IERR = @ERROR , $IEXTENDED = @EXTENDED
    __UNZIP_CLEAN ( $OSHELLFOLDER , $OPERSISTF )
    RETURN SETERROR ( $IERR , $IEXTENDED , $BRET )
ENDFUNC
FUNC UNZIP_SAVEFILETOFILEONCE ( $SZIP , $SFILE , $SDESTINATION )
    LOCAL $OSHELLFOLDER , $OPERSISTF
    LOCAL $SRET = UNZIP_SAVEFILETOBINARY ( $SZIP , $SFILE , $OSHELLFOLDER , $OPERSISTF )
    LOCAL $IERR = @ERROR , $IEXTENDED = @EXTENDED
    __UNZIP_CLEAN ( $OSHELLFOLDER , $OPERSISTF )
    RETURN SETERROR ( $IERR , $IEXTENDED , $SRET )
ENDFUNC
FUNC UNZIP_SAVEFILETOFILE ( $SZIP , $SFILE , $SDESTINATION , BYREF $OSHELLFOLDER , BYREF $OPERSISTF )
    LOCAL $BBINARY = UNZIP_SAVEFILETOBINARY ( $SZIP , $SFILE , $OSHELLFOLDER , $OPERSISTF )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , "" )
    LOCAL $HFILE = FILEOPEN ( $SDESTINATION , 0x1a )
    IF $HFILE <> + 0xffffffff THEN
        FILEWRITE ( $HFILE , $BBINARY )
        FILECLOSE ( $HFILE )
        RETURN $SDESTINATION
    ENDIF
    RETURN SETERROR ( 0x1 , 0x0 , "" )
ENDFUNC
FUNC UNZIP_SAVEFILETOBINARY ( $SZIP , $SFILE , BYREF $OSHELLFOLDER , BYREF $OPERSISTF , $IWANTEDSIZE = DEFAULT )
    LOCAL $BNORELEASE = ISOBJ ( $OSHELLFOLDER ) AND ISOBJ ( $OPERSISTF )
    LOCAL CONST $S_OK = 0x0 , $S_FALSE = 0x1
    LOCAL $OSTREAM = UNZIP_SAVEFILETOSTREAM ( $SZIP , $SFILE , $OSHELLFOLDER , $OPERSISTF , NOT $BNORELEASE )
    IF @ERROR THEN
        LOCAL $IERR = @ERROR
        __UNZIP_CLEAN ( $OSHELLFOLDER , $OPERSISTF , $BNORELEASE )
        RETURN SETERROR ( 0x1 , $IERR , 0x0 )
    ENDIF
    $BNORELEASE = TRUE
    LOCAL ENUM $STREAM_SEEK_SET = 0x0 , $STREAM_SEEK_CUR , $STREAM_SEEK_END
    $OSTREAM .Seek ( 0x0 , $STREAM_SEEK_SET , 0x0 )
    LOCAL $ISIZE
    $OSTREAM .Seek ( 0x0 , $STREAM_SEEK_END , $ISIZE )
    IF $ISIZE = 0x0 THEN
        $OSTREAM = 0x0
        __UNZIP_CLEAN ( $OSHELLFOLDER , $OPERSISTF , $BNORELEASE )
        RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
    ENDIF
    $OSTREAM .Seek ( 0x0 , $STREAM_SEEK_SET , 0x0 )
    IF $ISIZE = + 0xffffffff THEN $ISIZE = 0x40000
    IF ( $IWANTEDSIZE <> DEFAULT ) AND ( $IWANTEDSIZE < $ISIZE ) THEN $ISIZE = $IWANTEDSIZE
    LOCAL $TBINARY = DLLSTRUCTCREATE ( "byte[" & $ISIZE & "]" )
    LOCAL $BBINARY = BINARY ( "" ) , $IREAD , $IOVERALLREAD
    WHILE 0x1
        SWITCH $OSTREAM .Read ( $TBINARY , $ISIZE , $IREAD )
            CASE $S_OK
            $IOVERALLREAD += $IREAD
            $BBINARY &= DLLSTRUCTGETDATA ( $TBINARY , 0x1 )
            CASE $S_FALSE
            $IOVERALLREAD += $IREAD
            $BBINARY &= BINARYMID ( DLLSTRUCTGETDATA ( $TBINARY , 0x1 ) , 0x1 , $IREAD )
            EXITLOOP
            CASE ELSE
            EXITLOOP
        ENDSWITCH
        IF $IOVERALLREAD <= $ISIZE THEN EXITLOOP
    WEND
    $OSTREAM = 0x0
    __UNZIP_CLEAN ( $OSHELLFOLDER , $OPERSISTF , $BNORELEASE )
    RETURN $BBINARY
ENDFUNC
FUNC UNZIP_SAVEFILETOSTREAM ( $SZIP , $SFILE , BYREF $OSHELLFOLDER , BYREF $OPERSISTF , $BINIT = TRUE )
    LOCAL CONST $S_OK = 0x0
    IF $BINIT THEN
        LOCAL $OCLASSFACTORY = __UNZIP_DLLGETCLASSOBJECT ( $HZIPFLDR_DLL , $CLSID_CZIPFOLDER , $SIID_ICLASSFACTORY , $TAGICLASSFACTORY )
        IF @ERROR THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
        LOCAL $PSHELLFOLDER
        $OCLASSFACTORY .CreateInstance ( 0x0 , $SIID_ISHELLFOLDER , $PSHELLFOLDER )
        $OSHELLFOLDER = OBJCREATEINTERFACE ( $PSHELLFOLDER , $SIID_ISHELLFOLDER , $TAGISHELLFOLDER )
        IF @ERROR THEN RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
        $OPERSISTF = OBJCREATEINTERFACE ( $PSHELLFOLDER , $SIID_IPERSISTFILE , $TAGIPERSISTFILE )
        IF @ERROR THEN
            $OPERSISTF = OBJCREATEINTERFACE ( $PSHELLFOLDER , $SIID_IPERSISTFOLDER , $TAGIPERSISTFOLDER )
            IF @ERROR THEN
                RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
            ELSE
                IF $OPERSISTF .Initialize ( __UNZIP_SHPARSEDISPLAYNAME ( $SZIP ) ) < $S_OK THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
            ENDIF
        ELSE
            LOCAL CONST $STGM_READ = 0x0
            IF $OPERSISTF .Load ( $SZIP , $STGM_READ ) < $S_OK THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
        ENDIF
    ENDIF
    LOCAL CONST $SFGAO_STREAM = 0x400000
    LOCAL $PPIDL = 0x0
    LOCAL $IATTRIBUTES = $SFGAO_STREAM
    IF $OSHELLFOLDER .ParseDisplayName ( 0x0 , 0x0 , $SFILE , 0x0 , $PPIDL , $IATTRIBUTES ) < $S_OK THEN
        $SFILE = STRINGREPLACE ( $SFILE , "\" , "/" )
        IF $OSHELLFOLDER .ParseDisplayName ( 0x0 , 0x0 , $SFILE , 0x0 , $PPIDL , $IATTRIBUTES ) < $S_OK THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    ENDIF
    LOCAL $PSTREAM
    IF $OSHELLFOLDER .BindToStorage ( $PPIDL , 0x0 , $SIID_ISTREAM , $PSTREAM ) <> $S_OK THEN RETURN SETERROR ( 0x6 , __UNZIP_COTASKMEMFREE ( $PPIDL ) , 0x0 )
    __UNZIP_COTASKMEMFREE ( $PPIDL )
    LOCAL $OSTREAM = OBJCREATEINTERFACE ( $PSTREAM , $SIID_ISTREAM , $TAGISTREAM )
    IF @ERROR THEN RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    RETURN $OSTREAM
ENDFUNC
FUNC __UNZIP_CLEAN ( BYREF $VPARAM1 , BYREF $VPARAM2 , $BNORELEASE = FALSE )
    IF $BNORELEASE THEN RETURN
    $VPARAM1 = 0x0
    $VPARAM2 = 0x0
ENDFUNC
FUNC __UNZIP_DLLGETCLASSOBJECT ( $SDLL , $SCLSID , $SIID , $TAGINTERFACE = "" )
    LOCAL $TCLSID = __UNZIP_GUIDFROMSTRING ( $SCLSID )
    LOCAL $TIID = __UNZIP_GUIDFROMSTRING ( $SIID )
    LOCAL $ACALL = DLLCALL ( $SDLL , "long" , "DllGetClassObject" , "struct*" , $TCLSID , "struct*" , $TIID , "ptr*" , 0x0 )
    IF @ERROR OR $ACALL [ 0x0 ] THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    LOCAL $OOBJ = OBJCREATEINTERFACE ( $ACALL [ 0x3 ] , $SIID , $TAGINTERFACE )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
    RETURN $OOBJ
ENDFUNC
FUNC __UNZIP_SHPARSEDISPLAYNAME ( $SPATH )
    LOCAL $ACALL = DLLCALL ( "shell32.dll" , "long" , "SHParseDisplayName" , "wstr" , $SPATH , "ptr" , 0x0 , "ptr*" , 0x0 , "ulong" , 0x0 , "ulong*" , 0x0 )
    IF @ERROR OR $ACALL [ 0x0 ] THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    RETURN $ACALL [ 0x3 ]
ENDFUNC
FUNC __UNZIP_COTASKMEMFREE ( $PMEMORY )
    DLLCALL ( "ole32.dll" , "none" , "CoTaskMemFree" , "ptr" , $PMEMORY )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    RETURN 0x1
ENDFUNC
FUNC __UNZIP_GUIDFROMSTRING ( $SGUID )
    LOCAL $TGUID = DLLSTRUCTCREATE ( "byte[16]" )
    DLLCALL ( "ole32.dll" , "long" , "CLSIDFromString" , "wstr" , $SGUID , "struct*" , $TGUID )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    RETURN $TGUID
ENDFUNC
FUNC __UNZIP_STRINGLENW ( $VSTRING )
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "int" , "lstrlenW" , "struct*" , $VSTRING )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    RETURN $ACALL [ 0x0 ]
ENDFUNC
GLOBAL CONST $TAGWINTRUST_FILE_INFO = "DWORD cbStruct;" & "ptr pcwszFilePath;" & "HWND hFile;" & "ptr  pgKnownSubject;"
GLOBAL CONST $TAGWINTRUST_DATA = "DWORD cbStruct;" & "ptr   pPolicyCallbackData;" & "ptr   pSIPClientData;" & "DWORD dwUIChoice;" & "DWORD fdwRevocationChecks;" & "DWORD dwUnionChoice;" & "ptr   pInfoStruct;" & "DWORD dwStateAction;" & "HWND  hWVTStateData;" & "ptr   pwszURLReference;" & "DWORD dwProvFlags;" & "DWORD dwUIContext;"
GLOBAL CONST $TAGWINTRUST_CATALOG_INFO = "DWORD cbStruct;" & "DWORD   dwCatalogVersion;" & "ptr   pcwszCatalogFilePath;" & "ptr pcwszMemberTag;" & "ptr pcwszMemberFilePath;" & "HANDLE hMemberFile;" & "ptr   pbCalculatedFileHash;" & "DWORD cbCalculatedFileHash;" & "ptr  pcCatalogContext;"
GLOBAL $TAGCMSG_SIGNER_INFO = "DWORD dwVersion;" & "DWORD   Issuer_cbData;" & "ptr   Issuer_pbData;" & "DWORD SerialNumber_cbData;" & "ptr SerialNumber_pbData;" & "ptr HashAlgorithm_pszObjId;" & "DWORD HashAlgorithm_Parameters_cbData;" & "ptr HashAlgorithm_Parameters_pbData;" & "ptr HashEncryptionAlgorithm_pszObjId;" & "DWORD HashEncryptionAlgorithm_Parameters_cbData;" & "ptr HashEncryptionAlgorithm_Parameters_pbData;" & "DWORD EncryptedHash_cbData;" & "ptr EncryptedHash_pbData;" & "DWORD AuthAttrs_cAttr;" & "ptr AuthAttrs_rgAttr;" & "DWORD UnauthAttrs_cAttr;" & "ptr UnauthAttrs_rgAttr;" & "DWORD dwUIContext;"
IF @OSARCH = "X64" THEN $TAGCMSG_SIGNER_INFO = STRINGREGEXPREPLACE ( $TAGCMSG_SIGNER_INFO , "DWORD" , "UINT64" )
GLOBAL $TAGCERT_INFO = "DWORD dwVersion;" & "DWORD SerialNumber_cbData;" & "ptr SerialNumber_pbData;" & "ptr SignatureAlgorithm_pszObjId;" & "DWORD SignatureAlgorithm_Parameters_cbData;" & "ptr SignatureAlgorithm_Parameters_pbData;" & "DWORD Issuer_cbData;" & "ptr Issuer_pbData;" & "DWORD NotBefore_dwLowDateTime;" & "DWORD NotBefore_dwHighDateTime;" & "DWORD NotAfter_dwLowDateTime;" & "DWORD NotAfter_dwHighDateTime;" & "DWORD Subject_cbData;" & "ptr Subject_pbData;" & "ptr SubjectPublicKeyInfo_Algorithm_pszObjId;" & "DWORD SubjectPublicKeyInfo_Algorithm_Parameters_cbData;" & "ptr SubjectPublicKeyInfo_Algorithm_Parameters_pbData;" & "DWORD SubjectPublicKeyInfo_PublicKey_cbData;" & "ptr SubjectPublicKeyInfo_PublicKey_pbData;" & "DWORD IssuerUniqueId_cbData;" & "ptr IssuerUniqueId_pbData;" & "DWORD SubjectUniqueId_cbData;" & "ptr SubjectUniqueId_pbData;" & "DWORD cExtension;" & "ptr rgExtension;"
IF @OSARCH = "X64" THEN $TAGCERT_INFO = STRINGREGEXPREPLACE ( $TAGCERT_INFO , "DWORD" , "UINT64" )
GLOBAL $WINTRUST_ACTION_GENERIC_VERIFY_V2 = _WINAPI_GUIDFROMSTRING ( "{00AAC56B-CD44-11D0-8CC2-00C04FC295EE}" )
FUNC _WINVERIFYTRUST ( $FILEPATH , $CATPATH = "" , $CATMEMBERTAG = "" , $DWPROVFLAGS = 0x10 , $ICODEPAGE = 0x0 )
    IF STRINGLEN ( $FILEPATH ) > 0x3e8 THEN RETURN SETERROR ( + 0xffffffff , 0x0 , "File Path too large." )
    LOCAL $WSZSOURCEFILE = _WINAPI_MULTIBYTETOWIDECHAR ( $FILEPATH , $ICODEPAGE , 0x1 )
    IF @ERROR THEN RETURN SETERROR ( + 0xffffffff , 0x0 , "Could not convert FilePath to WideChar." )
    IF STRINGLEN ( $CATPATH ) = 0x0 THEN
        $WINTRUST_FILE_INFO = DLLSTRUCTCREATE ( $TAGWINTRUST_FILE_INFO )
        DLLSTRUCTSETDATA ( $WINTRUST_FILE_INFO , "cbStruct" , DLLSTRUCTGETSIZE ( $WINTRUST_FILE_INFO ) )
        DLLSTRUCTSETDATA ( $WINTRUST_FILE_INFO , "pcwszFilePath" , DLLSTRUCTGETPTR ( $WSZSOURCEFILE ) )
        DLLSTRUCTSETDATA ( $WINTRUST_FILE_INFO , "hFile" , 0x0 )
        DLLSTRUCTSETDATA ( $WINTRUST_FILE_INFO , "pgKnownSubject" , 0x0 )
        $PINFOSTRUCT = DLLSTRUCTGETPTR ( $WINTRUST_FILE_INFO )
        $DWUNIONCHOICE = 0x1
        $DWSTATEACTION = 0x0
    ELSE
        $WSZCATALOGFILE = _WINAPI_MULTIBYTETOWIDECHAR ( $CATPATH , $ICODEPAGE , 0x1 )
        IF @ERROR THEN RETURN SETERROR ( + 0xffffffff , 0x0 , "Could not convert CatPath to WideChar." )
        $WSZFILETAG = _WINAPI_MULTIBYTETOWIDECHAR ( $CATMEMBERTAG , $ICODEPAGE , 0x1 )
        IF @ERROR THEN RETURN SETERROR ( + 0xffffffff , 0x0 , "Could not convert CatMemberTag to WideChar." )
        $WINTRUST_CATALOG_INFO = DLLSTRUCTCREATE ( $TAGWINTRUST_CATALOG_INFO )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "cbStruct" , DLLSTRUCTGETSIZE ( $WINTRUST_CATALOG_INFO ) )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "dwCatalogVersion" , 0x0 )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "pcwszCatalogFilePath" , DLLSTRUCTGETPTR ( $WSZCATALOGFILE ) )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "pcwszMemberTag" , DLLSTRUCTGETPTR ( $WSZFILETAG ) )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "pcwszMemberFilePath" , DLLSTRUCTGETPTR ( $WSZSOURCEFILE ) )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "hMemberFile" , 0x0 )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "pbCalculatedFileHash" , 0x0 )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "cbCalculatedFileHash" , 0x0 )
        DLLSTRUCTSETDATA ( $WINTRUST_CATALOG_INFO , "pcCatalogContext" , 0x0 )
        $PINFOSTRUCT = DLLSTRUCTGETPTR ( $WINTRUST_CATALOG_INFO )
        $DWUNIONCHOICE = 0x2
        $DWSTATEACTION = 0x4
    ENDIF
    $WINTRUST_DATA = DLLSTRUCTCREATE ( $TAGWINTRUST_DATA )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "cbStruct" , DLLSTRUCTGETSIZE ( $WINTRUST_DATA ) )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "pPolicyCallbackData" , 0x0 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "pSIPClientData" , 0x0 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "dwUIChoice" , 0x2 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "fdwRevocationChecks" , 0x0 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "dwUnionChoice" , $DWUNIONCHOICE )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "pInfoStruct" , $PINFOSTRUCT )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "dwStateAction" , $DWSTATEACTION )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "hWVTStateData" , 0x0 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "pwszURLReference" , 0x0 )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "dwProvFlags" , $DWPROVFLAGS )
    DLLSTRUCTSETDATA ( $WINTRUST_DATA , "dwUIContext" , 0x0 )
    $PGUID = DLLSTRUCTGETPTR ( $WINTRUST_ACTION_GENERIC_VERIFY_V2 )
    $PWINTRUST_DATA = DLLSTRUCTGETPTR ( $WINTRUST_DATA )
    $STATUS = DLLCALL ( "wintrust.dll" , "long" , "WinVerifyTrust" , "HWND" , 0x0 , "ptr" , $PGUID , "ptr" , $PWINTRUST_DATA )
    IF @ERROR THEN SETERROR ( + 0xffffffff , 0x0 , "WinVerifyTrust Error." )
    RETURN $STATUS [ 0x0 ]
ENDFUNC
FUNC _GETSIGNATUREINFO ( $FILEPATH , $ICODEPAGE = 0x0 )
    DIM $EMPTY_ANSWER [ 0x3 ] = [ "" , "" , "" ]
    DIM $CERTINFO [ 0x3 ] = [ "" , "" , "" ]
    LOCAL $WSZSOURCEFILE = _WINAPI_MULTIBYTETOWIDECHAR ( $FILEPATH , $ICODEPAGE , 0x1 , TRUE )
    IF @ERROR THEN RETURN $EMPTY_ANSWER
    LOCAL $ACALL = DLLCALL ( "Crypt32.dll" , "bool" , "CryptQueryObject" , "dword" , 0x1 , "wstr" , $WSZSOURCEFILE , "dword" , 0x400 , "dword" , 0x2 , "dword" , 0x0 , "dword*" , 0x0 , "dword*" , 0x0 , "dword*" , 0x0 , "handle*" , 0x0 , "handle*" , 0x0 , "ptr" , 0x0 )
    IF $ACALL [ 0x0 ] = 0x0 THEN RETURN $EMPTY_ANSWER
    LOCAL $HSTORE = $ACALL [ 0x9 ]
    LOCAL $HMSG = $ACALL [ 0xa ]
    IF NOT $HMSG THEN RETURN $EMPTY_ANSWER
    $ACALL = DLLCALL ( "Crypt32.dll" , "bool" , "CryptMsgGetParam" , "handle" , $HMSG , "dword" , 0x6 , "dword" , 0x0 , "ptr" , 0x0 , "dword*" , 0x0 )
    LOCAL $ISIZE = $ACALL [ 0x5 ]
    LOCAL $PSIGNERINFO = DLLSTRUCTCREATE ( "byte[" & $ISIZE & "]" )
    $ACALL = DLLCALL ( "Crypt32.dll" , "bool" , "CryptMsgGetParam" , "handle" , $HMSG , "dword" , 0x6 , "dword" , 0x0 , "ptr" , DLLSTRUCTGETPTR ( $PSIGNERINFO ) , "dword*" , DLLSTRUCTGETSIZE ( $PSIGNERINFO ) )
    LOCAL $CMSG_SIGNER_INFO = DLLSTRUCTCREATE ( $TAGCMSG_SIGNER_INFO , DLLSTRUCTGETPTR ( $PSIGNERINFO ) )
    LOCAL $CERT_INFO = DLLSTRUCTCREATE ( $TAGCERT_INFO )
    DLLSTRUCTSETDATA ( $CERT_INFO , "Issuer_cbData" , DLLSTRUCTGETDATA ( $CMSG_SIGNER_INFO , "Issuer_cbData" ) )
    DLLSTRUCTSETDATA ( $CERT_INFO , "Issuer_pbData" , DLLSTRUCTGETDATA ( $CMSG_SIGNER_INFO , "Issuer_pbData" ) )
    DLLSTRUCTSETDATA ( $CERT_INFO , "SerialNumber_cbData" , DLLSTRUCTGETDATA ( $CMSG_SIGNER_INFO , "SerialNumber_cbData" ) )
    DLLSTRUCTSETDATA ( $CERT_INFO , "SerialNumber_pbData" , DLLSTRUCTGETDATA ( $CMSG_SIGNER_INFO , "SerialNumber_pbData" ) )
    $ACALL = DLLCALL ( "Crypt32.dll" , "ptr" , "CertFindCertificateInStore" , "HANDLE" , $HSTORE , "DWORD" , 0x1 + 0x10000 , "DWORD" , 0x0 , "DWORD" , 0xb0000 , "ptr" , DLLSTRUCTGETPTR ( $CERT_INFO ) , "ptr" , 0x0 )
    IF $ACALL [ 0x0 ] = 0x0 THEN RETURN $EMPTY_ANSWER
    LOCAL $PCERTCONTEXT = $ACALL [ 0x0 ]
    $ACALL = DLLCALL ( "Crypt32.dll" , "DWORD" , "CertGetNameStringW" , "ptr" , $PCERTCONTEXT , "DWORD" , 0x4 , "DWORD" , 0x0 , "ptr" , 0x0 , "ptr" , 0x0 , "DWORD" , 0x0 )
    IF $ACALL [ 0x0 ] = 0x0 THEN RETURN $EMPTY_ANSWER
    LOCAL $DWSIZE = $ACALL [ 0x0 ]
    LOCAL $SZSIGNERNAME = DLLSTRUCTCREATE ( "wchar[" & $DWSIZE & "]" )
    $ACALL = DLLCALL ( "Crypt32.dll" , "DWORD" , "CertGetNameStringW" , "ptr" , $PCERTCONTEXT , "DWORD" , 0x4 , "DWORD" , 0x0 , "ptr" , 0x0 , "ptr" , DLLSTRUCTGETPTR ( $SZSIGNERNAME ) , "DWORD" , $DWSIZE )
    IF $ACALL [ 0x0 ] = 0x0 THEN RETURN $EMPTY_ANSWER
    $CERTINFO [ 0x1 ] = DLLSTRUCTGETDATA ( $SZSIGNERNAME , 0x1 )
    RETURN $CERTINFO
ENDFUNC
IF NOT OBJEVENT ( "AutoIt.Error" ) THEN
    GLOBAL CONST $_ZIP_COMERRORHANDLER = OBJEVENT ( "AutoIt.Error" , "_Zip_COMErrorFunc" )
ENDIF
FUNC _ZIP_ADDITEM ( $SZIPFILE , $SITEM , $SDESTDIR = "" , $IFLAG = 0x15 )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SITEM ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    IF NOT FILEEXISTS ( $SITEM ) THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    IF _ISFULLPATH ( $SDESTDIR ) THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    $SITEM = _ZIP_PATHSTRIPSLASH ( $SITEM )
    $SDESTDIR = _ZIP_PATHSTRIPSLASH ( $SDESTDIR )
    LOCAL $SNAMEONLY = _ZIP_PATHNAMEONLY ( $SITEM )
    LOCAL $IOVERWRITE = 0x0
    IF BITAND ( $IFLAG , 0x1 ) THEN
        $IOVERWRITE = 0x1
        $IFLAG -= 0x1
    ENDIF
    LOCAL $STEST = $SNAMEONLY
    IF $SDESTDIR <> "" THEN $STEST = $SDESTDIR & "\" & $SNAMEONLY
    LOCAL $ITEMEXISTS = _ZIP_ITEMEXISTS ( $SZIPFILE , $STEST )
    IF @ERROR THEN RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    IF $ITEMEXISTS THEN
        IF @EXTENDED THEN
            RETURN SETERROR ( 0x8 , 0x0 , 0x0 )
        ELSE
            IF $IOVERWRITE THEN
                _ZIP_INTERNALDELETE ( $SZIPFILE , $STEST )
                IF @ERROR THEN RETURN SETERROR ( 0xa , 0x0 , 0x0 )
            ELSE
                RETURN SETERROR ( 0x9 , 0x0 , 0x0 )
            ENDIF
        ENDIF
    ENDIF
    LOCAL $STEMPFILE = ""
    IF $SDESTDIR <> "" THEN
        $STEMPFILE = _ZIP_ADDPATH ( $SZIPFILE , $SDESTDIR )
        IF @ERROR THEN RETURN SETERROR ( 0xb , 0x0 , 0x0 )
    ENDIF
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SDESTDIR )
    $ONS .CopyHere ( $SITEM , $IFLAG )
    DO
        SLEEP ( 0xfa )
    UNTIL ISOBJ ( $ONS .ParseName ( $SNAMEONLY ) )
    IF $STEMPFILE <> "" THEN
        _ZIP_INTERNALDELETE ( $SZIPFILE , $SDESTDIR & "\" & $STEMPFILE )
        IF @ERROR THEN RETURN SETERROR ( 0xc , 0x0 , 0x0 )
    ENDIF
    RETURN 0x1
ENDFUNC
FUNC _ZIP_COMERRORFUNC ( )
ENDFUNC
FUNC _ZIP_COUNT ( $SZIPFILE )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    RETURN $ONS .Items ( ) .Count
ENDFUNC
FUNC _ZIP_COUNTALL ( $SZIPFILE , $SSUB = "" , $IFILECOUNT = 0x0 , $IFOLDERCOUNT = 0x0 )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SSUB )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OITEMS = $ONS .Items ( ) , $ACOUNT , $SSUB2
    FOR $OITEM IN $OITEMS
        $SSUB2 = $SSUB
        IF $OITEM .IsFolder THEN
            $IFOLDERCOUNT += 0x1
            IF $SSUB2 = "" THEN
                $SSUB2 = $OITEM .Name
            ELSE
                $SSUB2 &= "\" & $OITEM .Name
            ENDIF
            $ACOUNT = _ZIP_COUNTALL ( $SZIPFILE , $SSUB2 , $IFILECOUNT , $IFOLDERCOUNT )
            $IFILECOUNT = $ACOUNT [ 0x0 ]
            $IFOLDERCOUNT = $ACOUNT [ 0x1 ]
        ELSE
            $IFILECOUNT += 0x1
        ENDIF
    NEXT
    DIM $ACOUNT [ 0x2 ] = [ $IFILECOUNT , $IFOLDERCOUNT ]
    RETURN $ACOUNT
ENDFUNC
FUNC _ZIP_CREATE ( $SFILENAME , $IOVERWRITE = 0x0 )
    IF FILEEXISTS ( $SFILENAME ) AND NOT $IOVERWRITE THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    LOCAL $HFP = FILEOPEN ( $SFILENAME , 0x2 + 0x8 + 0x10 )
    IF $HFP = + 0xffffffff THEN RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
    FILEWRITE ( $HFP , BINARY ( "0x504B0506000000000000000000000000000000000000" ) )
    FILECLOSE ( $HFP )
    RETURN $SFILENAME
ENDFUNC
FUNC _ZIP_DELETEITEM ( $SZIPFILE , $SFILENAME )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $SPATH = ""
    $SFILENAME = _ZIP_PATHSTRIPSLASH ( $SFILENAME )
    IF STRINGINSTR ( $SFILENAME , "\" ) THEN
        $SPATH = _ZIP_PATHPATHONLY ( $SFILENAME )
        $SFILENAME = _ZIP_PATHNAMEONLY ( $SFILENAME )
    ENDIF
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SPATH )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OFOLDERITEM = $ONS .ParseName ( $SFILENAME )
    IF NOT ISOBJ ( $OFOLDERITEM ) THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    LOCAL $OVERBS = $OFOLDERITEM .Verbs ( )
    IF NOT ISOBJ ( $OVERBS ) THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    FOR $OVERB IN $OVERBS
        IF STRINGREPLACE ( $OVERB .Name , "&" , "" ) = "delete" THEN
            $OVERB .DoIt ( )
            IF ISOBJ ( $ONS .ParseName ( $SFILENAME ) ) THEN
                RETURN SETERROR ( 0x8 , 0x0 , 0x0 )
            ELSE
                RETURN 0x1
            ENDIF
        ENDIF
    NEXT
    RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
ENDFUNC
FUNC _ZIP_ITEMEXISTS ( $SZIPFILE , $SITEM )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $SPATH = ""
    $SITEM = _ZIP_PATHSTRIPSLASH ( $SITEM )
    IF STRINGINSTR ( $SITEM , "\" ) THEN
        $SPATH = _ZIP_PATHPATHONLY ( $SITEM )
        $SITEM = _ZIP_PATHNAMEONLY ( $SITEM )
    ENDIF
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SPATH )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OITEM = $ONS .ParseName ( $SITEM )
    IF ISOBJ ( $OITEM ) THEN RETURN SETEXTENDED ( NUMBER ( $OITEM .IsFolder ) , 0x1 )
    RETURN 0x0
ENDFUNC
FUNC _ZIP_LIST ( $SZIPFILE )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $AARRAY [ 0x1 ] = [ 0x0 ]
    LOCAL $OLIST = $ONS .Items ( )
    FOR $OITEM IN $OLIST
        $AARRAY [ 0x0 ] += 0x1
        REDIM $AARRAY [ $AARRAY [ 0x0 ] + 0x1 ]
        $AARRAY [ $AARRAY [ 0x0 ] ] = $OITEM .Name
    NEXT
    RETURN $AARRAY
ENDFUNC
FUNC _ZIP_LISTALL ( $SZIPFILE , $IFULLPATH = 0x1 )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $AARRAY [ 0x1 ] = [ 0x0 ]
    _ZIP_LISTALL_INTERNAL ( $SZIPFILE , "" , $AARRAY , $IFULLPATH )
    IF @ERROR THEN
        RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    ELSE
        RETURN $AARRAY
    ENDIF
ENDFUNC
FUNC _ZIP_SEARCH ( $SZIPFILE , $SSEARCHSTRING )
    LOCAL $ALIST = _ZIP_LISTALL ( $SZIPFILE )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    LOCAL $AARRAY [ 0x1 ] = [ 0x0 ] , $SNAME
    FOR $I = 0x1 TO $ALIST [ 0x0 ]
        $SNAME = $ALIST [ $I ]
        IF STRINGINSTR ( $SNAME , "\" ) THEN
            $SNAME = _ZIP_PATHNAMEONLY ( $SNAME )
        ENDIF
        IF STRINGINSTR ( $SNAME , $SSEARCHSTRING ) THEN
            $AARRAY [ 0x0 ] += 0x1
            REDIM $AARRAY [ $AARRAY [ 0x0 ] + 0x1 ]
            $AARRAY [ $AARRAY [ 0x0 ] ] = $ALIST [ $I ]
        ENDIF
    NEXT
    IF $AARRAY [ 0x0 ] = 0x0 THEN
        RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    ELSE
        RETURN $AARRAY
    ENDIF
ENDFUNC
FUNC _ZIP_SEARCHINFILE ( $SZIPFILE , $SSEARCHSTRING )
    LOCAL $ALIST = _ZIP_LISTALL ( $SZIPFILE )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    LOCAL $STEMPDIR = _ZIP_CREATETEMPDIR ( )
    IF @ERROR THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    _ZIP_UNZIPALL ( $SZIPFILE , $STEMPDIR )
    IF @ERROR THEN
        DIRREMOVE ( $STEMPDIR , 0x1 )
        RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    ENDIF
    LOCAL $AARRAY [ 0x1 ] = [ 0x0 ] , $SDATA
    FOR $I = 0x1 TO $ALIST [ 0x0 ]
        $SDATA = FILEREAD ( $STEMPDIR & "\" & $ALIST [ $I ] )
        IF STRINGINSTR ( $SDATA , $SSEARCHSTRING ) THEN
            $AARRAY [ 0x0 ] += 0x1
            REDIM $AARRAY [ $AARRAY [ 0x0 ] + 0x1 ]
            $AARRAY [ $AARRAY [ 0x0 ] ] = $ALIST [ $I ]
        ENDIF
    NEXT
    DIRREMOVE ( $STEMPDIR , 0x1 )
    IF $AARRAY [ 0x0 ] = 0x0 THEN
        RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    ELSE
        RETURN $AARRAY
    ENDIF
ENDFUNC
FUNC _ZIP_UNZIP ( $SZIPFILE , $SFILENAME , $SDESTPATH , $IFLAG = 0x15 )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) OR NOT _ISFULLPATH ( $SDESTPATH ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $STEMPDIR = _ZIP_TEMPDIRNAME ( $SZIPFILE )
    LOCAL $SPATH = ""
    $SFILENAME = _ZIP_PATHSTRIPSLASH ( $SFILENAME )
    IF STRINGINSTR ( $SFILENAME , "\" ) THEN
        $SPATH = _ZIP_PATHPATHONLY ( $SFILENAME )
        $SFILENAME = _ZIP_PATHNAMEONLY ( $SFILENAME )
    ENDIF
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SPATH )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OFOLDERITEM = $ONS .ParseName ( $SFILENAME )
    IF NOT ISOBJ ( $OFOLDERITEM ) THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    $SDESTPATH = _ZIP_PATHSTRIPSLASH ( $SDESTPATH )
    IF NOT FILEEXISTS ( $SDESTPATH ) THEN
        DIRCREATE ( $SDESTPATH )
        IF @ERROR THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    ENDIF
    LOCAL $ONS2 = _ZIP_GETNAMESPACE ( $SDESTPATH )
    IF NOT ISOBJ ( $ONS2 ) THEN RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    LOCAL $IOVERWRITE = 0x0
    IF BITAND ( $IFLAG , 0x1 ) THEN
        $IOVERWRITE = 0x1
        $IFLAG -= 0x1
    ENDIF
    LOCAL $SDESTFULLPATH = $SDESTPATH & "\" & $SFILENAME
    IF FILEEXISTS ( $SDESTFULLPATH ) THEN
        IF $IOVERWRITE THEN
            IF STRINGINSTR ( FILEGETATTRIB ( $SDESTFULLPATH ) , "D" ) THEN
                IF NOT DIRREMOVE ( $SDESTFULLPATH , 0x1 ) THEN RETURN SETERROR ( 0x8 , 0x0 , 0x0 )
            ELSE
                IF NOT FILEDELETE ( $SDESTFULLPATH ) THEN RETURN SETERROR ( 0x8 , 0x0 , 0x0 )
            ENDIF
        ELSE
            RETURN SETERROR ( 0x9 , 0x0 , 0x0 )
        ENDIF
    ENDIF
    $ONS2 .CopyHere ( $OFOLDERITEM , $IFLAG )
    DIRREMOVE ( $STEMPDIR , 0x1 )
    IF FILEEXISTS ( $SDESTFULLPATH ) THEN
        RETURN 0x1
    ELSE
        RETURN SETERROR ( 0xa , 0x0 , 0x0 )
    ENDIF
ENDFUNC
FUNC _ZIP_UNZIPALL ( $SZIPFILE , $SDESTPATH , $IFLAG = 0x14 )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) OR NOT _ISFULLPATH ( $SDESTPATH ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $STEMPDIR = _ZIP_TEMPDIRNAME ( $SZIPFILE )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    $SDESTPATH = _ZIP_PATHSTRIPSLASH ( $SDESTPATH )
    IF NOT FILEEXISTS ( $SDESTPATH ) THEN
        DIRCREATE ( $SDESTPATH )
        IF @ERROR THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    ENDIF
    LOCAL $ONS2 = _ZIP_GETNAMESPACE ( $SDESTPATH )
    IF NOT ISOBJ ( $ONS2 ) THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    $ONS2 .CopyHere ( $ONS .Items ( ) , $IFLAG )
    DIRREMOVE ( $STEMPDIR , 0x1 )
    IF FILEEXISTS ( $SDESTPATH & "\" & $ONS .Items ( ) .Item ( $ONS .Items ( ) .Count + 0xffffffff ) .Name ) THEN
        RETURN 0x1
    ELSE
        RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    ENDIF
ENDFUNC
FUNC _ISFULLPATH ( $SPATH )
    IF STRINGINSTR ( $SPATH , ":\" ) THEN
        RETURN TRUE
    ELSE
        RETURN FALSE
    ENDIF
ENDFUNC
FUNC _ZIP_ADDPATH ( $SZIPFILE , $SPATH )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    $SPATH = _ZIP_PATHSTRIPSLASH ( $SPATH )
    LOCAL $SNEWPATH = "" , $SFILENAME = ""
    IF $SPATH <> "" THEN
        LOCAL $ADIR = STRINGSPLIT ( $SPATH , "\" ) , $OTEST
        FOR $I = 0x1 TO $ADIR [ 0x0 ]
            $OTEST = $ONS .ParseName ( $ADIR [ $I ] )
            IF ISOBJ ( $OTEST ) THEN
                IF NOT $OTEST .IsFolder THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
                $ONS = $OTEST .GetFolder
            ELSE
                LOCAL $STEMPDIR = _ZIP_CREATETEMPDIR ( )
                IF @ERROR THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
                LOCAL $OTEMP = _ZIP_GETNAMESPACE ( $STEMPDIR )
                FOR $I = $I TO $ADIR [ 0x0 ]
                    $SNEWPATH &= $ADIR [ $I ] & "\"
                NEXT
                DIRCREATE ( $STEMPDIR & "\" & $SNEWPATH )
                $SFILENAME = _ZIP_CREATETEMPNAME ( )
                $SNEWPATH &= $SFILENAME
                FILECLOSE ( FILEOPEN ( $STEMPDIR & "\" & $SNEWPATH , 0x2 + 0x8 ) )
                $ONS .CopyHere ( $OTEMP .Items ( ) )
                DO
                    SLEEP ( 0xfa )
                UNTIL _ZIP_ITEMEXISTS ( $SZIPFILE , $SNEWPATH )
                DIRREMOVE ( $STEMPDIR , 0x1 )
                EXITLOOP
            ENDIF
        NEXT
    ENDIF
    RETURN $SFILENAME
ENDFUNC
FUNC _ZIP_CREATETEMPDIR ( )
    LOCAL $S_TEMPNAME
    DO
        $S_TEMPNAME = ""
        WHILE STRINGLEN ( $S_TEMPNAME ) < 0x7
            $S_TEMPNAME &= CHR ( RANDOM ( 0x61 , 0x7a , 0x1 ) )
        WEND
        $S_TEMPNAME = @TEMPDIR & "\~" & $S_TEMPNAME & ".tmp"
    UNTIL NOT FILEEXISTS ( $S_TEMPNAME )
    IF NOT DIRCREATE ( $S_TEMPNAME ) THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    RETURN $S_TEMPNAME
ENDFUNC
FUNC _ZIP_CREATETEMPNAME ( )
    LOCAL $GUID = DLLSTRUCTCREATE ( "dword Data1;word Data2;word Data3;byte Data4[8]" )
    DLLCALL ( "ole32.dll" , "int" , "CoCreateGuid" , "ptr" , DLLSTRUCTGETPTR ( $GUID ) )
    LOCAL $RET = DLLCALL ( "ole32.dll" , "int" , "StringFromGUID2" , "ptr" , DLLSTRUCTGETPTR ( $GUID ) , "wstr" , "" , "int" , 0x28 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , 0x0 , "" )
    RETURN STRINGREGEXPREPLACE ( $RET [ 0x2 ] , "[}{-]" , "" )
ENDFUNC
FUNC _ZIP_DLLCHK ( )
    IF NOT FILEEXISTS ( @SYSTEMDIR & "\zipfldr.dll" ) THEN RETURN SETERROR ( 0x1 , 0x0 , 0x0 )
    IF NOT REGREAD ( "HKEY_CLASSES_ROOT\CLSID\{E88DCCE0-B7B3-11d1-A9F0-00AA0060FA31}" , "" ) THEN RETURN SETERROR ( 0x2 , 0x0 , 0x0 )
    RETURN 0x1
ENDFUNC
FUNC _ZIP_GETNAMESPACE ( $SZIPFILE , $SPATH = "" )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $OAPP = OBJCREATE ( "Shell.Application" )
    LOCAL $ONS = $OAPP .NameSpace ( $SZIPFILE )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    IF $SPATH <> "" THEN
        LOCAL $APATH = STRINGSPLIT ( $SPATH , "\" )
        LOCAL $OITEM
        FOR $I = 0x1 TO $APATH [ 0x0 ]
            $OITEM = $ONS .ParseName ( $APATH [ $I ] )
            IF NOT ISOBJ ( $OITEM ) THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
            $ONS = $OITEM .GetFolder
            IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
        NEXT
    ENDIF
    RETURN $ONS
ENDFUNC
FUNC _ZIP_INTERNALDELETE ( $SZIPFILE , $SFILENAME )
    IF NOT _ZIP_DLLCHK ( ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x0 )
    IF NOT _ISFULLPATH ( $SZIPFILE ) THEN RETURN SETERROR ( 0x3 , 0x0 , 0x0 )
    LOCAL $SPATH = ""
    $SFILENAME = _ZIP_PATHSTRIPSLASH ( $SFILENAME )
    IF STRINGINSTR ( $SFILENAME , "\" ) THEN
        $SPATH = _ZIP_PATHPATHONLY ( $SFILENAME )
        $SFILENAME = _ZIP_PATHNAMEONLY ( $SFILENAME )
    ENDIF
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SPATH )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OFOLDERITEM = $ONS .ParseName ( $SFILENAME )
    IF NOT ISOBJ ( $OFOLDERITEM ) THEN RETURN SETERROR ( 0x5 , 0x0 , 0x0 )
    LOCAL $STEMPDIR = _ZIP_CREATETEMPDIR ( )
    IF @ERROR THEN RETURN SETERROR ( 0x6 , 0x0 , 0x0 )
    LOCAL $OAPP = OBJCREATE ( "Shell.Application" )
    $OAPP .NameSpace ( $STEMPDIR ) .MoveHere ( $OFOLDERITEM , 0x14 )
    DIRREMOVE ( $STEMPDIR , 0x1 )
    $OFOLDERITEM = $ONS .ParseName ( $SFILENAME )
    IF ISOBJ ( $OFOLDERITEM ) THEN
        RETURN SETERROR ( 0x7 , 0x0 , 0x0 )
    ELSE
        RETURN 0x1
    ENDIF
ENDFUNC
FUNC _ZIP_LISTALL_INTERNAL ( $SZIPFILE , $SSUB , BYREF $AARRAY , $IFULLPATH , $SPREFIX = "" )
    LOCAL $ONS = _ZIP_GETNAMESPACE ( $SZIPFILE , $SSUB )
    IF NOT ISOBJ ( $ONS ) THEN RETURN SETERROR ( 0x4 , 0x0 , 0x0 )
    LOCAL $OLIST = $ONS .Items ( ) , $SSUB2
    FOR $OITEM IN $OLIST
        $SSUB2 = $SSUB
        IF $OITEM .IsFolder THEN
            IF $SSUB2 = "" THEN
                $SSUB2 = $OITEM .Name
            ELSE
                $SSUB2 &= "\" & $OITEM .Name
            ENDIF
            IF $IFULLPATH THEN
                _ZIP_LISTALL_INTERNAL ( $SZIPFILE , $SSUB2 , $AARRAY , $IFULLPATH , $SSUB2 & "\" )
                IF @ERROR THEN RETURN SETERROR ( 0x4 )
            ELSE
                _ZIP_LISTALL_INTERNAL ( $SZIPFILE , $SSUB2 , $AARRAY , $IFULLPATH , "" )
                IF @ERROR THEN RETURN SETERROR ( 0x4 )
            ENDIF
        ELSE
            $AARRAY [ 0x0 ] += 0x1
            REDIM $AARRAY [ $AARRAY [ 0x0 ] + 0x1 ]
            $AARRAY [ $AARRAY [ 0x0 ] ] = $SPREFIX & $OITEM .Name
        ENDIF
    NEXT
ENDFUNC
FUNC _ZIP_PATHNAMEONLY ( $SPATH )
    RETURN STRINGREGEXPREPLACE ( $SPATH , ".*\\" , "" )
ENDFUNC
FUNC _ZIP_PATHPATHONLY ( $SPATH )
    RETURN STRINGREGEXPREPLACE ( $SPATH , "^(.*)\\.*?$" , "${1}" )
ENDFUNC
FUNC _ZIP_PATHSTRIPSLASH ( $SSTRING )
    RETURN STRINGREGEXPREPLACE ( $SSTRING , "(^\\+|\\+$)" , "" )
ENDFUNC
FUNC _ZIP_TEMPDIRNAME ( $SZIPFILE )
    LOCAL $I = 0x0 , $STEMP , $SNAME = _ZIP_PATHNAMEONLY ( $SZIPFILE )
    DO
        $I += 0x1
        $STEMP = @TEMPDIR & "\Temporary Directory " & $I & " for " & $SNAME
    UNTIL NOT FILEEXISTS ( $STEMP )
    RETURN $STEMP
ENDFUNC
GLOBAL $__G_ATIMERS_ATIMERIDS [ 0x1 ] [ 0x3 ]
FUNC _TIMER_DIFF ( $ITIMESTAMP )
    RETURN 0x3e8 * ( __TIMER_QUERYPERFORMANCECOUNTER ( ) - $ITIMESTAMP ) / __TIMER_QUERYPERFORMANCEFREQUENCY ( )
ENDFUNC
FUNC _TIMER_GETIDLETIME ( )
    LOCAL $TSTRUCT = DLLSTRUCTCREATE ( "uint;dword" )
    DLLSTRUCTSETDATA ( $TSTRUCT , 0x1 , DLLSTRUCTGETSIZE ( $TSTRUCT ) )
    LOCAL $ACALL = DLLCALL ( "user32.dll" , "bool" , "GetLastInputInfo" , "struct*" , $TSTRUCT )
    IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0xa , @EXTENDED , 0x0 )
    LOCAL $AVTICKS = DLLCALL ( "kernel32.dll" , "dword" , "GetTickCount" )
    IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0x14 , @EXTENDED , 0x0 )
    LOCAL $IDIFF = $AVTICKS [ 0x0 ] - DLLSTRUCTGETDATA ( $TSTRUCT , 0x2 )
    IF $IDIFF < 0x0 THEN RETURN SETEXTENDED ( 0x1 , $AVTICKS [ 0x0 ] )
    RETURN $IDIFF
ENDFUNC
FUNC _TIMER_GETTIMERID ( $WPARAM )
    LOCAL $_ITIMERID = DEC ( HEX ( $WPARAM , 0x8 ) ) , $IMAX = UBOUND ( $__G_ATIMERS_ATIMERIDS ) + 0xffffffff
    FOR $X = 0x1 TO $IMAX
        IF $_ITIMERID = $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x1 ] THEN RETURN $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ]
    NEXT
    RETURN 0x0
ENDFUNC
FUNC _TIMER_INIT ( )
    RETURN __TIMER_QUERYPERFORMANCECOUNTER ( )
ENDFUNC
FUNC _TIMER_KILLALLTIMERS ( $HWND )
    LOCAL $INUMTIMERS = $__G_ATIMERS_ATIMERIDS [ 0x0 ] [ 0x0 ]
    IF $INUMTIMERS = 0x0 THEN RETURN FALSE
    LOCAL $ACALL , $HCALLBACK = 0x0
    FOR $X = $INUMTIMERS TO 0x1 STEP + 0xffffffff
        IF ISHWND ( $HWND ) THEN
            $ACALL = DLLCALL ( "user32.dll" , "bool" , "KillTimer" , "hwnd" , $HWND , "uint_ptr" , $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x1 ] )
        ELSE
            $ACALL = DLLCALL ( "user32.dll" , "bool" , "KillTimer" , "hwnd" , $HWND , "uint_ptr" , $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ] )
        ENDIF
        IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0xa , @EXTENDED , FALSE )
        $HCALLBACK = $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x2 ]
        IF $HCALLBACK <> 0x0 THEN DLLCALLBACKFREE ( $HCALLBACK )
        $__G_ATIMERS_ATIMERIDS [ 0x0 ] [ 0x0 ] -= 0x1
    NEXT
    REDIM $__G_ATIMERS_ATIMERIDS [ 0x1 ] [ 0x3 ]
    RETURN TRUE
ENDFUNC
FUNC _TIMER_KILLTIMER ( $HWND , $ITIMERID )
    LOCAL $ACALL [ 0x1 ] = [ 0x0 ] , $HCALLBACK = 0x0 , $IUBOUND = UBOUND ( $__G_ATIMERS_ATIMERIDS ) + 0xffffffff
    FOR $X = 0x1 TO $IUBOUND
        IF $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ] = $ITIMERID THEN
            IF ISHWND ( $HWND ) THEN
                $ACALL = DLLCALL ( "user32.dll" , "bool" , "KillTimer" , "hwnd" , $HWND , "uint_ptr" , $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x1 ] )
            ELSE
                $ACALL = DLLCALL ( "user32.dll" , "bool" , "KillTimer" , "hwnd" , $HWND , "uint_ptr" , $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ] )
            ENDIF
            IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0xa , @EXTENDED , FALSE )
            $HCALLBACK = $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x2 ]
            IF $HCALLBACK <> 0x0 THEN DLLCALLBACKFREE ( $HCALLBACK )
            FOR $I = $X TO $IUBOUND + 0xffffffff
                $__G_ATIMERS_ATIMERIDS [ $I ] [ 0x0 ] = $__G_ATIMERS_ATIMERIDS [ $I + 0x1 ] [ 0x0 ]
                $__G_ATIMERS_ATIMERIDS [ $I ] [ 0x1 ] = $__G_ATIMERS_ATIMERIDS [ $I + 0x1 ] [ 0x1 ]
                $__G_ATIMERS_ATIMERIDS [ $I ] [ 0x2 ] = $__G_ATIMERS_ATIMERIDS [ $I + 0x1 ] [ 0x2 ]
            NEXT
            REDIM $__G_ATIMERS_ATIMERIDS [ UBOUND ( $__G_ATIMERS_ATIMERIDS + 0xffffffff ) ] [ 0x3 ]
            $__G_ATIMERS_ATIMERIDS [ 0x0 ] [ 0x0 ] -= 0x1
            EXITLOOP
        ENDIF
    NEXT
    RETURN $ACALL [ 0x0 ] <> 0x0
ENDFUNC
FUNC __TIMER_QUERYPERFORMANCECOUNTER ( )
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "QueryPerformanceCounter" , "int64*" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , + 0xffffffff )
    RETURN SETEXTENDED ( $ACALL [ 0x0 ] , $ACALL [ 0x1 ] )
ENDFUNC
FUNC __TIMER_QUERYPERFORMANCEFREQUENCY ( )
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "QueryPerformanceFrequency" , "int64*" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    RETURN SETEXTENDED ( $ACALL [ 0x0 ] , $ACALL [ 0x1 ] )
ENDFUNC
FUNC _TIMER_SETTIMER ( $HWND , $IELAPSE = 0xfa , $STIMERFUNC = "" , $ITIMERID = + 0xffffffff )
    #Au3Stripper_Ignore_Funcs=$sTimerFunc
    LOCAL $ACALL [ 0x1 ] = [ 0x0 ] , $PTIMERFUNC = 0x0 , $HCALLBACK = 0x0 , $IINDEX = $__G_ATIMERS_ATIMERIDS [ 0x0 ] [ 0x0 ] + 0x1
    IF $ITIMERID = + 0xffffffff THEN
        REDIM $__G_ATIMERS_ATIMERIDS [ $IINDEX + 0x1 ] [ 0x3 ]
        $__G_ATIMERS_ATIMERIDS [ 0x0 ] [ 0x0 ] = $IINDEX
        $ITIMERID = $IINDEX + 0x3e8
        FOR $X = 0x1 TO $IINDEX
            IF $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ] = $ITIMERID THEN
                $ITIMERID = $ITIMERID + 0x1
                $X = 0x0
            ENDIF
        NEXT
        IF $STIMERFUNC <> "" THEN
            $HCALLBACK = DLLCALLBACKREGISTER ( $STIMERFUNC , "none" , "hwnd;uint;uint_ptr;dword" )
            IF $HCALLBACK = 0x0 THEN RETURN SETERROR ( + 0xffffffff , + 0xffffffff , 0x0 )
            $PTIMERFUNC = DLLCALLBACKGETPTR ( $HCALLBACK )
            IF $PTIMERFUNC = 0x0 THEN RETURN SETERROR ( + 0xffffffff , + 0xfffffffe , 0x0 )
        ENDIF
        $ACALL = DLLCALL ( "user32.dll" , "uint_ptr" , "SetTimer" , "hwnd" , $HWND , "uint_ptr" , $ITIMERID , "uint" , $IELAPSE , "ptr" , $PTIMERFUNC )
        IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0xa , @EXTENDED , 0x0 )
        $__G_ATIMERS_ATIMERIDS [ $IINDEX ] [ 0x0 ] = $ACALL [ 0x0 ]
        $__G_ATIMERS_ATIMERIDS [ $IINDEX ] [ 0x1 ] = $ITIMERID
        $__G_ATIMERS_ATIMERIDS [ $IINDEX ] [ 0x2 ] = $HCALLBACK
    ELSE
        FOR $X = 0x1 TO $IINDEX + 0xffffffff
            IF $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x0 ] = $ITIMERID THEN
                IF ISHWND ( $HWND ) THEN $ITIMERID = $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x1 ]
                $HCALLBACK = $__G_ATIMERS_ATIMERIDS [ $X ] [ 0x2 ]
                IF $HCALLBACK <> 0x0 THEN
                    $PTIMERFUNC = DLLCALLBACKGETPTR ( $HCALLBACK )
                    IF $PTIMERFUNC = 0x0 THEN RETURN SETERROR ( + 0xffffffff , + 0xfffffff4 , 0x0 )
                ENDIF
                $ACALL = DLLCALL ( "user32.dll" , "uint_ptr" , "SetTimer" , "hwnd" , $HWND , "uint_ptr" , $ITIMERID , "uint" , $IELAPSE , "ptr" , $PTIMERFUNC )
                IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR + 0x14 , @EXTENDED , 0x0 )
                EXITLOOP
            ENDIF
        NEXT
    ENDIF
    RETURN $ACALL [ 0x0 ]
ENDFUNC
#ignorefunc __SQLite_Inline_Version, __SQLite_Inline_Modified
GLOBAL $__G_HDLL_SQLITE = 0x0
GLOBAL $__G_HDB_SQLITE = 0x0
GLOBAL $__G_BUTF8ERRORMSG_SQLITE = FALSE
GLOBAL $__G_HPRINTCALLBACK_SQLITE = __SQLITE_CONSOLEWRITE
GLOBAL $__G_BSAFEMODESTATE_SQLITE = TRUE
GLOBAL $__G_AHDBS_SQLITE [ 0x1 ] = [ "" ]
GLOBAL $__G_AHQUERYS_SQLITE [ 0x1 ] = [ "" ]
GLOBAL $__G_HMSVCRTDLL_SQLITE = 0x0
FUNC _SQLITE_STARTUP ( $SDLL_FILENAME = "" , $BUTF8ERRORMSG = FALSE , $IFORCELOCAL = 0x0 , $HPRINTCALLBACK = $__G_HPRINTCALLBACK_SQLITE )
    IF $SDLL_FILENAME = DEFAULT OR $SDLL_FILENAME = + 0xffffffff THEN $SDLL_FILENAME = ""
    IF $HPRINTCALLBACK = DEFAULT THEN $HPRINTCALLBACK = __SQLITE_CONSOLEWRITE
    $__G_HPRINTCALLBACK_SQLITE = $HPRINTCALLBACK
    IF $BUTF8ERRORMSG = DEFAULT THEN $BUTF8ERRORMSG = FALSE
    $__G_BUTF8ERRORMSG_SQLITE = $BUTF8ERRORMSG
    IF $SDLL_FILENAME = "" THEN $SDLL_FILENAME = "sqlite3.dll"
    IF @AUTOITX64 AND ( STRINGINSTR ( $SDLL_FILENAME , "_x64" ) = 0x0 ) THEN $SDLL_FILENAME = STRINGREPLACE ( $SDLL_FILENAME , ".dll" , "_x64.dll" )
    LOCAL $IEXT = 0x0
    LOCAL $HDLL = DLLOPEN ( $SDLL_FILENAME )
    IF $HDLL = + 0xffffffff THEN
        $__G_HDLL_SQLITE = 0x0
        RETURN SETERROR ( 0x1 , $IEXT , "" )
    ELSE
        $__G_HDLL_SQLITE = $HDLL
        RETURN SETEXTENDED ( $IEXT , $SDLL_FILENAME )
    ENDIF
ENDFUNC
FUNC _SQLITE_SHUTDOWN ( )
    IF $__G_HDLL_SQLITE > 0x0 THEN DLLCLOSE ( $__G_HDLL_SQLITE )
    $__G_HDLL_SQLITE = 0x0
    IF $__G_HMSVCRTDLL_SQLITE > 0x0 THEN DLLCLOSE ( $__G_HMSVCRTDLL_SQLITE )
    $__G_HMSVCRTDLL_SQLITE = 0x0
ENDFUNC
FUNC _SQLITE_OPEN ( $SDATABASE_FILENAME = DEFAULT , $IACCESSMODE = DEFAULT , $IENCODING = DEFAULT )
    IF NOT $__G_HDLL_SQLITE THEN RETURN SETERROR ( 0x3 , 0x15 , 0x0 )
    IF $SDATABASE_FILENAME = DEFAULT OR NOT ISSTRING ( $SDATABASE_FILENAME ) THEN $SDATABASE_FILENAME = ":memory:"
    LOCAL $TFILENAME = __SQLITE_STRINGTOUTF8STRUCT ( $SDATABASE_FILENAME )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , 0x0 )
    IF $IACCESSMODE = DEFAULT THEN $IACCESSMODE = BITOR ( 0x2 , 0x4 )
    LOCAL $BOLDBASE = FILEEXISTS ( $SDATABASE_FILENAME )
    IF $IENCODING = DEFAULT THEN
        $IENCODING = 0x0
    ENDIF
    LOCAL $AVRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_open_v2" , "struct*" , $TFILENAME , "ptr*" , 0x0 , "int" , $IACCESSMODE , "ptr" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x0 )
    IF $AVRVAL [ 0x0 ] <> 0x0 THEN
        __SQLITE_REPORTERROR ( $AVRVAL [ 0x2 ] , "_SQLite_Open" )
        _SQLITE_CLOSE ( $AVRVAL [ 0x2 ] )
        RETURN SETERROR ( + 0xffffffff , $AVRVAL [ 0x0 ] , 0x0 )
    ENDIF
    $__G_HDB_SQLITE = $AVRVAL [ 0x2 ]
    __SQLITE_HADD ( $__G_AHDBS_SQLITE , $AVRVAL [ 0x2 ] )
    IF NOT $BOLDBASE THEN
        LOCAL $AENCODING [ 0x3 ] = [ "8" , "16" , "16be" ]
        _SQLITE_EXEC ( $AVRVAL [ 0x2 ] , 'PRAGMA encoding="UTF-' & $AENCODING [ $IENCODING ] & '";' )
    ENDIF
    RETURN SETEXTENDED ( $AVRVAL [ 0x0 ] , $AVRVAL [ 0x2 ] )
ENDFUNC
FUNC _SQLITE_GETTABLE ( $HDB , $SSQL , BYREF $ARESULT , BYREF $IROWS , BYREF $ICOLUMNS , $ICHARSIZE = + 0xffffffff )
    $ARESULT = ""
    IF __SQLITE_HCHK ( $HDB , 0x1 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    IF $ICHARSIZE = "" OR $ICHARSIZE < 0x1 OR $ICHARSIZE = DEFAULT THEN $ICHARSIZE = + 0xffffffff
    LOCAL $HQUERY
    LOCAL $R = _SQLITE_QUERY ( $HDB , $SSQL , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , $R )
    LOCAL $ADATAROW
    $R = _SQLITE_FETCHNAMES ( $HQUERY , $ADATAROW )
    LOCAL $IERROR = @ERROR
    IF $IERROR THEN
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( 0x3 , $IERROR , $R )
    ENDIF
    $ICOLUMNS = UBOUND ( $ADATAROW )
    LOCAL CONST $IROWSINCR = 0x40
    $IROWS = 0x0
    LOCAL $IALLOCROWS = $IROWSINCR
    DIM $ARESULT [ ( $IALLOCROWS + 0x1 ) * $ICOLUMNS + 0x1 ]
    FOR $IDX = 0x0 TO $ICOLUMNS + 0xffffffff
        IF $ICHARSIZE > 0x0 THEN
            $ADATAROW [ $IDX ] = STRINGLEFT ( $ADATAROW [ $IDX ] , $ICHARSIZE )
        ENDIF
        $ARESULT [ $IDX + 0x1 ] = $ADATAROW [ $IDX ]
    NEXT
    WHILE 0x1
        $R = _SQLITE_FETCHDATA ( $HQUERY , $ADATAROW , 0x0 , 0x0 , $ICOLUMNS )
        $IERROR = @ERROR
        SWITCH $R
            CASE 0x0
            $IROWS += 0x1
            IF $IROWS = $IALLOCROWS THEN
                $IALLOCROWS = ROUND ( $IALLOCROWS * 0x4 / 0x3 )
                REDIM $ARESULT [ ( $IALLOCROWS + 0x1 ) * $ICOLUMNS + 0x1 ]
            ENDIF
            FOR $J = 0x0 TO $ICOLUMNS + 0xffffffff
                IF $ICHARSIZE > 0x0 THEN
                    $ADATAROW [ $J ] = STRINGLEFT ( $ADATAROW [ $J ] , $ICHARSIZE )
                ENDIF
                $IDX += 0x1
                $ARESULT [ $IDX ] = $ADATAROW [ $J ]
            NEXT
            CASE 0x65
            EXITLOOP
            CASE ELSE
            $ARESULT = ""
            _SQLITE_QUERYFINALIZE ( $HQUERY )
            RETURN SETERROR ( 0x4 , $IERROR , $R )
        ENDSWITCH
    WEND
    $ARESULT [ 0x0 ] = ( $IROWS + 0x1 ) * $ICOLUMNS
    REDIM $ARESULT [ $ARESULT [ 0x0 ] + 0x1 ]
    RETURN ( 0x0 )
ENDFUNC
FUNC _SQLITE_GETTABLE2D ( $HDB , $SSQL , BYREF $ARESULT , BYREF $IROWS , BYREF $ICOLUMNS , $ICHARSIZE = + 0xffffffff , $BSWICHDIMENSIONS = FALSE )
    IF __SQLITE_HCHK ( $HDB , 0x1 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    IF $ICHARSIZE = "" OR $ICHARSIZE < 0x1 OR $ICHARSIZE = DEFAULT THEN $ICHARSIZE = + 0xffffffff
    LOCAL $SCALLBACK = "" , $BCALLBACK = FALSE
    $ARESULT = ""
    IF $BSWICHDIMENSIONS = DEFAULT THEN $BSWICHDIMENSIONS = FALSE
    LOCAL $HQUERY
    LOCAL $R = _SQLITE_QUERY ( $HDB , $SSQL , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , $R )
    IF $R <> 0x0 THEN
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( + 0xffffffff , 0x0 , $R )
    ENDIF
    $IROWS = 0x0
    LOCAL $IRVAL_STEP , $IERROR
    WHILE TRUE
        $IRVAL_STEP = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_step" , "ptr" , $HQUERY )
        IF @ERROR THEN
            $IERROR = @ERROR
            _SQLITE_QUERYFINALIZE ( $HQUERY )
            RETURN SETERROR ( 0x3 , $IERROR , 0x15 )
        ENDIF
        SWITCH $IRVAL_STEP [ 0x0 ]
            CASE 0x64
            $IROWS += 0x1
            CASE 0x65
            EXITLOOP
            CASE ELSE
            _SQLITE_QUERYFINALIZE ( $HQUERY )
            RETURN SETERROR ( 0x3 , $IERROR , $IRVAL_STEP [ 0x0 ] )
        ENDSWITCH
    WEND
    LOCAL $IRET = _SQLITE_QUERYRESET ( $HQUERY )
    IF @ERROR THEN
        $IERROR = @ERROR
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( 0x4 , $IERROR , $IRET )
    ENDIF
    LOCAL $ADATAROW
    $R = _SQLITE_FETCHNAMES ( $HQUERY , $ADATAROW )
    IF @ERROR THEN
        $IERROR = @ERROR
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( 0x5 , $IERROR , $R )
    ENDIF
    $ICOLUMNS = UBOUND ( $ADATAROW )
    IF $ICOLUMNS <= 0x0 THEN
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( + 0xffffffff , 0x0 , 0x65 )
    ENDIF
    IF NOT $BCALLBACK THEN
        IF $BSWICHDIMENSIONS THEN
            DIM $ARESULT [ $ICOLUMNS ] [ $IROWS + 0x1 ]
            FOR $I = 0x0 TO $ICOLUMNS + 0xffffffff
                IF $ICHARSIZE > 0x0 THEN
                    $ADATAROW [ $I ] = STRINGLEFT ( $ADATAROW [ $I ] , $ICHARSIZE )
                ENDIF
                $ARESULT [ $I ] [ 0x0 ] = $ADATAROW [ $I ]
            NEXT
        ELSE
            DIM $ARESULT [ $IROWS + 0x1 ] [ $ICOLUMNS ]
            FOR $I = 0x0 TO $ICOLUMNS + 0xffffffff
                IF $ICHARSIZE > 0x0 THEN
                    $ADATAROW [ $I ] = STRINGLEFT ( $ADATAROW [ $I ] , $ICHARSIZE )
                ENDIF
                $ARESULT [ 0x0 ] [ $I ] = $ADATAROW [ $I ]
            NEXT
        ENDIF
    ENDIF
    IF $IROWS > 0x0 THEN
        FOR $I = 0x1 TO $IROWS
            $R = _SQLITE_FETCHDATA ( $HQUERY , $ADATAROW , 0x0 , 0x0 , $ICOLUMNS )
            IF @ERROR THEN
                $IERROR = @ERROR
                _SQLITE_QUERYFINALIZE ( $HQUERY )
                RETURN SETERROR ( 0x6 , $IERROR , $R )
            ENDIF
            IF NOT $BCALLBACK THEN
                FOR $J = 0x0 TO $ICOLUMNS + 0xffffffff
                    IF $ICHARSIZE > 0x0 THEN
                        $ADATAROW [ $J ] = STRINGLEFT ( $ADATAROW [ $J ] , $ICHARSIZE )
                    ENDIF
                    IF $BSWICHDIMENSIONS THEN
                        $ARESULT [ $J ] [ $I ] = $ADATAROW [ $J ]
                    ELSE
                        $ARESULT [ $I ] [ $J ] = $ADATAROW [ $J ]
                    ENDIF
                NEXT
            ENDIF
        NEXT
    ENDIF
    RETURN ( _SQLITE_QUERYFINALIZE ( $HQUERY ) )
ENDFUNC
FUNC _SQLITE_EXEC ( $HDB , $SSQL , $SCALLBACK = "" )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    IF $SCALLBACK <> "" THEN
        LOCAL $IROWS , $ICOLUMNS
        LOCAL $ARESULT = "SQLITE_CALLBACK:" & $SCALLBACK
        LOCAL $IRVAL = _SQLITE_GETTABLE2D ( $HDB , $SSQL , $ARESULT , $IROWS , $ICOLUMNS )
        IF @ERROR THEN RETURN SETERROR ( 0x3 , @ERROR , $IRVAL )
        RETURN $IRVAL
    ENDIF
    LOCAL $TSQL8 = __SQLITE_STRINGTOUTF8STRUCT ( $SSQL )
    IF @ERROR THEN RETURN SETERROR ( 0x4 , @ERROR , 0x0 )
    LOCAL $AVRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_exec" , "ptr" , $HDB , "struct*" , $TSQL8 , "ptr" , 0x0 , "ptr" , 0x0 , "ptr*" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    __SQLITE_SZFREE ( $AVRVAL [ 0x5 ] )
    IF $AVRVAL [ 0x0 ] <> 0x0 THEN
        __SQLITE_REPORTERROR ( $HDB , "_SQLite_Exec" , $SSQL )
        SETERROR ( + 0xffffffff )
    ENDIF
    RETURN $AVRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_LIBVERSION ( )
    IF $__G_HDLL_SQLITE = 0x0 THEN RETURN SETERROR ( 0x1 , 0x15 , 0x0 )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "str:cdecl" , "sqlite3_libversion" )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x0 )
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_LASTINSERTROWID ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "long:cdecl" , "sqlite3_last_insert_rowid" , "ptr" , $HDB )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x0 )
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_CHANGES ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "long:cdecl" , "sqlite3_changes" , "ptr" , $HDB )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x0 )
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_TOTALCHANGES ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "long:cdecl" , "sqlite3_total_changes" , "ptr" , $HDB )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x0 )
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_ERRCODE ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "long:cdecl" , "sqlite3_errcode" , "ptr" , $HDB )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_ERRMSG ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , @EXTENDED , "Library used incorrectly" )
    LOCAL $R = DLLCALL ( $__G_HDLL_SQLITE , "wstr:cdecl" , "sqlite3_errmsg16" , "ptr" , $HDB )
    IF @ERROR THEN
        __SQLITE_REPORTERROR ( $HDB , "_SQLite_ErrMsg" , DEFAULT , "Call Failed" )
        RETURN SETERROR ( 0x1 , @ERROR , "Library used incorrectly" )
    ENDIF
    RETURN $R [ 0x0 ]
ENDFUNC
FUNC _SQLITE_DISPLAY2DRESULT ( $ARESULT , $ICELLWIDTH = 0x0 , $BRETURN = FALSE )
    IF NOT ISARRAY ( $ARESULT ) OR UBOUND ( $ARESULT , 0x0 ) <> 0x2 OR $ICELLWIDTH < 0x0 THEN RETURN SETERROR ( 0x1 , 0x0 , "" )
    LOCAL $AICELLWIDTH
    IF $ICELLWIDTH = 0x0 OR $ICELLWIDTH = DEFAULT THEN
        LOCAL $ICELLWIDTHMAX
        DIM $AICELLWIDTH [ UBOUND ( $ARESULT , 0x2 ) ]
        FOR $IROW = 0x0 TO UBOUND ( $ARESULT , 0x1 ) + 0xffffffff
            FOR $ICOL = 0x0 TO UBOUND ( $ARESULT , 0x2 ) + 0xffffffff
                $ICELLWIDTHMAX = STRINGLEN ( $ARESULT [ $IROW ] [ $ICOL ] )
                IF $ICELLWIDTHMAX > $AICELLWIDTH [ $ICOL ] THEN
                    $AICELLWIDTH [ $ICOL ] = $ICELLWIDTHMAX
                ENDIF
            NEXT
        NEXT
    ENDIF
    LOCAL $SOUT = "" , $ICELLWIDTHUSED
    FOR $IROW = 0x0 TO UBOUND ( $ARESULT , 0x1 ) + 0xffffffff
        FOR $ICOL = 0x0 TO UBOUND ( $ARESULT , 0x2 ) + 0xffffffff
            IF $ICELLWIDTH = 0x0 THEN
                $ICELLWIDTHUSED = $AICELLWIDTH [ $ICOL ]
            ELSE
                $ICELLWIDTHUSED = $ICELLWIDTH
            ENDIF
            $SOUT &= STRINGFORMAT ( " %-" & $ICELLWIDTHUSED & "." & $ICELLWIDTHUSED & "s " , $ARESULT [ $IROW ] [ $ICOL ] )
        NEXT
        $SOUT &= @CRLF
        IF NOT $BRETURN THEN
            __SQLITE_PRINT ( $SOUT )
            $SOUT = ""
        ENDIF
    NEXT
    IF $BRETURN THEN RETURN $SOUT
ENDFUNC
FUNC _SQLITE_SETTIMEOUT ( $HDB = + 0xffffffff , $ITIMEOUT = 0x3e8 )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    IF $ITIMEOUT = DEFAULT THEN $ITIMEOUT = 0x3e8
    LOCAL $AVRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_busy_timeout" , "ptr" , $HDB , "int" , $ITIMEOUT )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $AVRVAL [ 0x0 ] <> 0x0 THEN SETERROR ( + 0xffffffff )
    RETURN $AVRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_QUERY ( $HDB , $SSQL , BYREF $HQUERY )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $IRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_prepare16_v2" , "ptr" , $HDB , "wstr" , $SSQL , "int" , + 0xffffffff , "ptr*" , 0x0 , "ptr*" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $IRVAL [ 0x0 ] <> 0x0 THEN
        __SQLITE_REPORTERROR ( $HDB , "_SQLite_Query" , $SSQL )
        RETURN SETERROR ( + 0xffffffff , 0x0 , $IRVAL [ 0x0 ] )
    ENDIF
    $HQUERY = $IRVAL [ 0x4 ]
    __SQLITE_HADD ( $__G_AHQUERYS_SQLITE , $IRVAL [ 0x4 ] )
    RETURN $IRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_FETCHDATA ( $HQUERY , BYREF $AROW , $BBINARY = FALSE , $BDONOTFINALIZE = FALSE , $ICOLUMNS = 0x0 )
    DIM $AROW [ 0x1 ]
    IF __SQLITE_HCHK ( $HQUERY , 0x7 , FALSE ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    IF $BBINARY = DEFAULT THEN $BBINARY = FALSE
    IF $BDONOTFINALIZE = DEFAULT THEN $BDONOTFINALIZE = FALSE
    LOCAL $IRVAL_STEP = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_step" , "ptr" , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $IRVAL_STEP [ 0x0 ] <> 0x64 THEN
        IF $BDONOTFINALIZE = FALSE AND $IRVAL_STEP [ 0x0 ] = 0x65 THEN
            _SQLITE_QUERYFINALIZE ( $HQUERY )
        ENDIF
        RETURN SETERROR ( + 0xffffffff , 0x0 , $IRVAL_STEP [ 0x0 ] )
    ENDIF
    IF NOT $ICOLUMNS THEN
        LOCAL $IRVAL_COLCNT = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_data_count" , "ptr" , $HQUERY )
        IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , 0x15 )
        IF $IRVAL_COLCNT [ 0x0 ] <= 0x0 THEN RETURN SETERROR ( + 0xffffffff , 0x0 , 0x65 )
        $ICOLUMNS = $IRVAL_COLCNT [ 0x0 ]
    ENDIF
    REDIM $AROW [ $ICOLUMNS ]
    FOR $I = 0x0 TO $ICOLUMNS + 0xffffffff
        LOCAL $IRVAL_COLTYPE = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_column_type" , "ptr" , $HQUERY , "int" , $I )
        IF @ERROR THEN RETURN SETERROR ( 0x4 , @ERROR , 0x15 )
        IF $IRVAL_COLTYPE [ 0x0 ] = 0x5 THEN
            $AROW [ $I ] = ""
            CONTINUELOOP
        ENDIF
        IF ( NOT $BBINARY ) AND ( $IRVAL_COLTYPE [ 0x0 ] <> 0x4 ) THEN
            LOCAL $SRVAL = DLLCALL ( $__G_HDLL_SQLITE , "wstr:cdecl" , "sqlite3_column_text16" , "ptr" , $HQUERY , "int" , $I )
            IF @ERROR THEN RETURN SETERROR ( 0x3 , @ERROR , 0x15 )
            $AROW [ $I ] = $SRVAL [ 0x0 ]
        ELSE
            LOCAL $VRESULT = DLLCALL ( $__G_HDLL_SQLITE , "ptr:cdecl" , "sqlite3_column_blob" , "ptr" , $HQUERY , "int" , $I )
            IF @ERROR THEN RETURN SETERROR ( 0x6 , @ERROR , 0x15 )
            LOCAL $ICOLBYTES = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_column_bytes" , "ptr" , $HQUERY , "int" , $I )
            IF @ERROR THEN RETURN SETERROR ( 0x5 , @ERROR , 0x15 )
            LOCAL $TRESULTSTRUCT = DLLSTRUCTCREATE ( "byte[" & $ICOLBYTES [ 0x0 ] & "]" , $VRESULT [ 0x0 ] )
            $AROW [ $I ] = BINARY ( DLLSTRUCTGETDATA ( $TRESULTSTRUCT , 0x1 ) )
        ENDIF
    NEXT
    RETURN 0x0
ENDFUNC
FUNC _SQLITE_CLOSE ( $HDB = + 0xffffffff )
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $IRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_close" , "ptr" , $HDB )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $IRVAL [ 0x0 ] <> 0x0 THEN
        __SQLITE_REPORTERROR ( $HDB , "_SQLite_Close" )
        RETURN SETERROR ( + 0xffffffff , 0x0 , $IRVAL [ 0x0 ] )
    ENDIF
    $__G_HDB_SQLITE = 0x0
    __SQLITE_HDEL ( $__G_AHDBS_SQLITE , $HDB )
    RETURN $IRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_SAFEMODE ( $BSAFEMODESTATE )
    $__G_BSAFEMODESTATE_SQLITE = ( $BSAFEMODESTATE = TRUE )
    RETURN 0x0
ENDFUNC
FUNC _SQLITE_QUERYFINALIZE ( $HQUERY )
    IF __SQLITE_HCHK ( $HQUERY , 0x2 , FALSE ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $AVRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_finalize" , "ptr" , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    __SQLITE_HDEL ( $__G_AHQUERYS_SQLITE , $HQUERY )
    IF $AVRVAL [ 0x0 ] <> 0x0 THEN SETERROR ( + 0xffffffff )
    RETURN $AVRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_QUERYRESET ( $HQUERY )
    IF __SQLITE_HCHK ( $HQUERY , 0x2 , FALSE ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $AVRVAL = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_reset" , "ptr" , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $AVRVAL [ 0x0 ] <> 0x0 THEN SETERROR ( + 0xffffffff )
    RETURN $AVRVAL [ 0x0 ]
ENDFUNC
FUNC _SQLITE_FETCHNAMES ( $HQUERY , BYREF $ANAMES )
    DIM $ANAMES [ 0x1 ]
    IF __SQLITE_HCHK ( $HQUERY , 0x3 , FALSE ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $AVDATACNT = DLLCALL ( $__G_HDLL_SQLITE , "int:cdecl" , "sqlite3_column_count" , "ptr" , $HQUERY )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , 0x15 )
    IF $AVDATACNT [ 0x0 ] <= 0x0 THEN RETURN SETERROR ( + 0xffffffff , 0x0 , 0x65 )
    REDIM $ANAMES [ $AVDATACNT [ 0x0 ] ]
    LOCAL $AVCOLNAME
    FOR $ICNT = 0x0 TO $AVDATACNT [ 0x0 ] + 0xffffffff
        $AVCOLNAME = DLLCALL ( $__G_HDLL_SQLITE , "wstr:cdecl" , "sqlite3_column_name16" , "ptr" , $HQUERY , "int" , $ICNT )
        IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , 0x15 )
        $ANAMES [ $ICNT ] = $AVCOLNAME [ 0x0 ]
    NEXT
    RETURN 0x0
ENDFUNC
FUNC _SQLITE_QUERYSINGLEROW ( $HDB , $SSQL , BYREF $AROW )
    $AROW = ""
    IF __SQLITE_HCHK ( $HDB , 0x2 ) THEN RETURN SETERROR ( @ERROR , 0x0 , 0x15 )
    LOCAL $HQUERY
    LOCAL $IRVAL = _SQLITE_QUERY ( $HDB , $SSQL , $HQUERY )
    IF @ERROR THEN
        _SQLITE_QUERYFINALIZE ( $HQUERY )
        RETURN SETERROR ( 0x1 , 0x0 , $IRVAL )
    ELSE
        $IRVAL = _SQLITE_FETCHDATA ( $HQUERY , $AROW )
        IF $IRVAL = 0x0 THEN
            _SQLITE_QUERYFINALIZE ( $HQUERY )
            IF @ERROR THEN
                RETURN SETERROR ( 0x4 , 0x0 , $IRVAL )
            ELSE
                RETURN 0x0
            ENDIF
        ELSE
            _SQLITE_QUERYFINALIZE ( $HQUERY )
            RETURN SETERROR ( 0x3 , 0x0 , $IRVAL )
        ENDIF
    ENDIF
ENDFUNC
FUNC _SQLITE_SQLITEEXE ( $SDATABASEFILE , $SINPUT , BYREF $SOUTPUT , $SSQLITEEXEFILENAME = "sqlite3.exe" , $BDEBUG = FALSE )
    IF $SSQLITEEXEFILENAME = + 0xffffffff OR $SSQLITEEXEFILENAME = DEFAULT THEN
        $SSQLITEEXEFILENAME = "sqlite3.exe"
        IF NOT FILEEXISTS ( $SSQLITEEXEFILENAME ) THEN
            LOCAL $SINLINEVERSION = "_" & CALL ( "__SQLite_Inline_Version" )
            IF @ERROR THEN $SINLINEVERSION = ""
            $SSQLITEEXEFILENAME = STRINGREPLACE ( $SSQLITEEXEFILENAME , ".exe" , "" ) & $SINLINEVERSION & ".exe"
            IF NOT FILEEXISTS ( $SSQLITEEXEFILENAME ) THEN RETURN SETERROR ( 0x2 , 0x0 , 0x15 )
        ENDIF
    ENDIF
    IF NOT FILEEXISTS ( $SDATABASEFILE ) THEN
        LOCAL $HNEWFILE = FILEOPEN ( $SDATABASEFILE , 0x2 + 0x8 )
        IF $HNEWFILE = + 0xffffffff THEN
            RETURN SETERROR ( 0x1 , 0x0 , 0xe )
        ENDIF
        FILECLOSE ( $HNEWFILE )
    ENDIF
    LOCAL $SINPUTFILE = _TEMPFILE ( ) , $SOUTPUTFILE = _TEMPFILE ( ) , $IRVAL = 0x0
    LOCAL $HINPUTFILE = FILEOPEN ( $SINPUTFILE , 0x2 )
    IF $HINPUTFILE > + 0xffffffff THEN
        $SINPUT = ".output stdout" & @CRLF & $SINPUT
        FILEWRITE ( $HINPUTFILE , $SINPUT )
        FILECLOSE ( $HINPUTFILE )
        LOCAL $SCMD = @COMSPEC & " /c " & FILEGETSHORTNAME ( $SSQLITEEXEFILENAME ) & '  "' & FILEGETSHORTNAME ( $SDATABASEFILE ) & '" > "' & FILEGETSHORTNAME ( $SOUTPUTFILE ) & '" < "' & FILEGETSHORTNAME ( $SINPUTFILE ) & '"'
        LOCAL $NERRORLEVEL = RUNWAIT ( $SCMD , @WORKINGDIR , @SW_HIDE )
        IF $BDEBUG = TRUE THEN
            LOCAL $NERRORTEMP = @ERROR
            IF @ERROR THEN __SQLITE_PRINT ( "@@ Debug(_SQLite_SQLiteExe) : $sCmd = " & $SCMD & @CRLF & ">ErrorLevel: " & $NERRORLEVEL & @CRLF )
            SETERROR ( $NERRORTEMP )
        ENDIF
        IF @ERROR = 0x1 OR $NERRORLEVEL = 0x1 THEN
            $IRVAL = 0x15
        ELSE
            $SOUTPUT = FILEREAD ( $SOUTPUTFILE , FILEGETSIZE ( $SOUTPUTFILE ) )
            IF STRINGINSTR ( $SOUTPUT , "SQL error:" , 0x1 ) > 0x0 OR STRINGINSTR ( $SOUTPUT , "Incomplete SQL:" , 0x1 ) > 0x0 THEN $IRVAL = 0x1
        ENDIF
    ELSE
        $IRVAL = 0xe
    ENDIF
    IF FILEEXISTS ( $SINPUTFILE ) THEN FILEDELETE ( $SINPUTFILE )
    SWITCH $IRVAL
        CASE 0x15
        SETERROR ( 0x2 )
        CASE 0x1
        SETERROR ( 0x3 )
        CASE 0xe
        SETERROR ( 0x4 )
    ENDSWITCH
    RETURN $IRVAL
ENDFUNC
FUNC _SQLITE_ENCODE ( $VDATA )
    IF ISNUMBER ( $VDATA ) THEN $VDATA = STRING ( $VDATA )
    IF NOT ISSTRING ( $VDATA ) AND NOT ISBINARY ( $VDATA ) THEN RETURN SETERROR ( 0x1 , 0x0 , "" )
    LOCAL $VRVAL = "X'"
    IF STRINGLOWER ( STRINGLEFT ( $VDATA , 0x2 ) ) = "0x" AND NOT ISBINARY ( $VDATA ) THEN
        FOR $ICNT = 0x1 TO STRINGLEN ( $VDATA )
            $VRVAL &= HEX ( ASC ( STRINGMID ( $VDATA , $ICNT , 0x1 ) ) , 0x2 )
        NEXT
    ELSE
        IF NOT ISBINARY ( $VDATA ) THEN $VDATA = STRINGTOBINARY ( $VDATA , 0x4 )
        $VRVAL &= HEX ( $VDATA )
    ENDIF
    $VRVAL &= "'"
    RETURN $VRVAL
ENDFUNC
FUNC _SQLITE_ESCAPE ( $SSTRING , $IBUFFSIZE = DEFAULT )
    IF $__G_HDLL_SQLITE = 0x0 THEN RETURN SETERROR ( 0x1 , 0x15 , "" )
    IF ISNUMBER ( $SSTRING ) THEN $SSTRING = STRING ( $SSTRING )
    LOCAL $TSQL8 = __SQLITE_STRINGTOUTF8STRUCT ( $SSTRING )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , 0x0 )
    LOCAL $ARVAL = DLLCALL ( $__G_HDLL_SQLITE , "ptr:cdecl" , "sqlite3_mprintf" , "str" , "'%q'" , "struct*" , $TSQL8 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , "" )
    IF $IBUFFSIZE = DEFAULT OR $IBUFFSIZE < 0x1 THEN $IBUFFSIZE = + 0xffffffff
    LOCAL $SRESULT = __SQLITE_SZSTRINGREAD ( $ARVAL [ 0x0 ] , $IBUFFSIZE )
    IF @ERROR THEN RETURN SETERROR ( 0x3 , @ERROR , "" )
    DLLCALL ( $__G_HDLL_SQLITE , "none:cdecl" , "sqlite3_free" , "ptr" , $ARVAL [ 0x0 ] )
    RETURN $SRESULT
ENDFUNC
FUNC _SQLITE_FASTENCODE ( $VDATA )
    IF NOT ISBINARY ( $VDATA ) THEN $VDATA = BINARY ( $VDATA )
    RETURN "X'" & STRINGTRIMLEFT ( $VDATA , 0x2 ) & "'"
ENDFUNC
FUNC _SQLITE_FASTESCAPE ( $SSTRING )
    IF ISNUMBER ( $SSTRING ) THEN $SSTRING = STRING ( $SSTRING )
    IF NOT ISSTRING ( $SSTRING ) THEN RETURN SETERROR ( 0x1 , 0x0 , "" )
    RETURN ( "'" & STRINGREPLACE ( $SSTRING , "'" , "''" , 0x0 , 0x1 ) & "'" )
ENDFUNC
FUNC __SQLITE_HCHK ( BYREF $HGENERIC , $NERROR , $BDB = TRUE )
    IF $__G_HDLL_SQLITE = 0x0 THEN RETURN SETERROR ( 0x1 , 0x15 , 0x15 )
    IF $HGENERIC = + 0xffffffff OR $HGENERIC = "" OR $HGENERIC = DEFAULT THEN
        IF NOT $BDB THEN RETURN SETERROR ( $NERROR , 0x0 , 0x1 )
        $HGENERIC = $__G_HDB_SQLITE
    ENDIF
    IF NOT $__G_BSAFEMODESTATE_SQLITE THEN RETURN 0x0
    IF $BDB THEN
        IF _ARRAYSEARCH ( $__G_AHDBS_SQLITE , $HGENERIC ) > 0x0 THEN RETURN 0x0
    ELSE
        IF _ARRAYSEARCH ( $__G_AHQUERYS_SQLITE , $HGENERIC ) > 0x0 THEN RETURN 0x0
    ENDIF
    RETURN SETERROR ( $NERROR , 0x0 , 0x1 )
ENDFUNC
FUNC __SQLITE_HADD ( BYREF $AHLISTS , $HGENERIC )
    _ARRAYADD ( $AHLISTS , $HGENERIC )
ENDFUNC
FUNC __SQLITE_HDEL ( BYREF $AHLISTS , $HGENERIC )
    LOCAL $IELEMENT = _ARRAYSEARCH ( $AHLISTS , $HGENERIC )
    IF $IELEMENT > 0x0 THEN _ARRAYDELETE ( $AHLISTS , $IELEMENT )
ENDFUNC
FUNC __SQLITE_VERSCMP ( $SFILE , $SVERSION )
    LOCAL $AVRVAL = DLLCALL ( $SFILE , "str:cdecl" , "sqlite3_libversion" )
    IF @ERROR THEN RETURN 0xb
    LOCAL $SFILEVERSION = STRINGSPLIT ( $AVRVAL [ 0x0 ] , "." )
    LOCAL $IMAINTVERSION = 0x0
    IF $SFILEVERSION [ 0x0 ] = 0x4 THEN $IMAINTVERSION = $SFILEVERSION [ 0x4 ]
    $SFILEVERSION = ( ( $SFILEVERSION [ 0x1 ] * 0x3e8 + $SFILEVERSION [ 0x2 ] ) * 0x3e8 + $SFILEVERSION [ 0x3 ] ) * 0x64 + $IMAINTVERSION
    IF $SVERSION < 0x989680 THEN $SVERSION = $SVERSION * 0x64
    IF $SFILEVERSION >= $SVERSION THEN RETURN 0x0
    RETURN 0x14
ENDFUNC
FUNC __SQLITE_HDBG ( )
    __SQLITE_PRINT ( "State : " & $__G_BSAFEMODESTATE_SQLITE & @CRLF )
    LOCAL $ATMP = $__G_AHDBS_SQLITE
    FOR $I = 0x0 TO UBOUND ( $ATMP ) + 0xffffffff
        __SQLITE_PRINT ( "$__g_ahDBs_SQLite     -> [" & $I & "]" & $ATMP [ $I ] & @CRLF )
    NEXT
    $ATMP = $__G_AHQUERYS_SQLITE
    FOR $I = 0x0 TO UBOUND ( $ATMP ) + 0xffffffff
        __SQLITE_PRINT ( "$__g_ahQuerys_SQLite  -> [" & $I & "]" & $ATMP [ $I ] & @CRLF )
    NEXT
ENDFUNC
FUNC __SQLITE_REPORTERROR ( $HDB , $SFUNCTION , $SQUERY = DEFAULT , $SERROR = DEFAULT , $VRETURNVALUE = DEFAULT , $ICURERR = @ERROR , $ICUREXT = @EXTENDED )
    IF @COMPILED THEN RETURN SETERROR ( $ICURERR , $ICUREXT )
    IF $SERROR = DEFAULT THEN $SERROR = _SQLITE_ERRMSG ( $HDB )
    IF $SQUERY = DEFAULT THEN $SQUERY = ""
    LOCAL $SOUT = "!   SQLite.au3 Error" & @CRLF
    $SOUT &= "--> Function: " & $SFUNCTION & @CRLF
    IF $SQUERY <> "" THEN $SOUT &= "--> Query:    " & $SQUERY & @CRLF
    $SOUT &= "--> Error:    " & $SERROR & @CRLF
    __SQLITE_PRINT ( $SOUT & @CRLF )
    IF NOT ( $VRETURNVALUE = DEFAULT ) THEN RETURN SETERROR ( $ICURERR , $ICUREXT , $VRETURNVALUE )
    RETURN SETERROR ( $ICURERR , $ICUREXT )
ENDFUNC
FUNC __SQLITE_SZSTRINGREAD ( $PPTR , $IMAXLEN = + 0xffffffff )
    IF $PPTR = 0x0 THEN RETURN ""
    IF $__G_HMSVCRTDLL_SQLITE < 0x1 THEN $__G_HMSVCRTDLL_SQLITE = DLLOPEN ( "msvcrt.dll" )
    LOCAL $ASTRLEN = DLLCALL ( $__G_HMSVCRTDLL_SQLITE , "ulong_ptr:cdecl" , "strlen" , "ptr" , $PPTR )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , "" )
    LOCAL $ILEN = $ASTRLEN [ 0x0 ] + 0x1
    LOCAL $TSTRING = DLLSTRUCTCREATE ( "byte[" & $ILEN & "]" , $PPTR )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , "" )
    LOCAL $IERROR = 0x0
    LOCAL $SRTN = __SQLITE_UTF8STRUCTTOSTRING ( $TSTRING )
    IF @ERROR THEN
        $IERROR = 0x3
    ENDIF
    IF $IMAXLEN <= 0x0 THEN
        RETURN SETERROR ( $IERROR , @EXTENDED , $SRTN )
    ELSE
        RETURN SETERROR ( $IERROR , @EXTENDED , STRINGLEFT ( $SRTN , $IMAXLEN ) )
    ENDIF
ENDFUNC
FUNC __SQLITE_SZFREE ( $PPTR , $ICURERR = @ERROR )
    IF $PPTR <> 0x0 THEN DLLCALL ( $__G_HDLL_SQLITE , "none:cdecl" , "sqlite3_free" , "ptr" , $PPTR )
    SETERROR ( $ICURERR )
ENDFUNC
FUNC __SQLITE_STRINGTOUTF8STRUCT ( $SSTRING )
    LOCAL $ARESULT = DLLCALL ( "kernel32.dll" , "int" , "WideCharToMultiByte" , "uint" , 0xfde9 , "dword" , 0x0 , "wstr" , $SSTRING , "int" , + 0xffffffff , "ptr" , 0x0 , "int" , 0x0 , "ptr" , 0x0 , "ptr" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , "" )
    LOCAL $TTEXT = DLLSTRUCTCREATE ( "char[" & $ARESULT [ 0x0 ] & "]" )
    $ARESULT = DLLCALL ( "kernel32.dll" , "int" , "WideCharToMultiByte" , "uint" , 0xfde9 , "dword" , 0x0 , "wstr" , $SSTRING , "int" , + 0xffffffff , "struct*" , $TTEXT , "int" , $ARESULT [ 0x0 ] , "ptr" , 0x0 , "ptr" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , "" )
    RETURN $TTEXT
ENDFUNC
FUNC __SQLITE_UTF8STRUCTTOSTRING ( $TTEXT )
    LOCAL $ARESULT = DLLCALL ( "kernel32.dll" , "int" , "MultiByteToWideChar" , "uint" , 0xfde9 , "dword" , 0x0 , "struct*" , $TTEXT , "int" , + 0xffffffff , "ptr" , 0x0 , "int" , 0x0 )
    IF @ERROR THEN RETURN SETERROR ( 0x1 , @ERROR , "" )
    LOCAL $TWSTR = DLLSTRUCTCREATE ( "wchar[" & $ARESULT [ 0x0 ] & "]" )
    $ARESULT = DLLCALL ( "kernel32.dll" , "int" , "MultiByteToWideChar" , "uint" , 0xfde9 , "dword" , 0x0 , "struct*" , $TTEXT , "int" , + 0xffffffff , "struct*" , $TWSTR , "int" , $ARESULT [ 0x0 ] )
    IF @ERROR THEN RETURN SETERROR ( 0x2 , @ERROR , "" )
    RETURN DLLSTRUCTGETDATA ( $TWSTR , 0x1 )
ENDFUNC
FUNC __SQLITE_CONSOLEWRITE ( $STEXT )
    CONSOLEWRITE ( $STEXT )
ENDFUNC
FUNC __SQLITE_PRINT ( $STEXT )
    IF ISFUNC ( $__G_HPRINTCALLBACK_SQLITE ) THEN
        IF $__G_BUTF8ERRORMSG_SQLITE THEN
            LOCAL $TSTR8 = __SQLITE_STRINGTOUTF8STRUCT ( $STEXT )
            $__G_HPRINTCALLBACK_SQLITE ( DLLSTRUCTGETDATA ( $TSTR8 , 0x1 ) )
        ELSE
            $__G_HPRINTCALLBACK_SQLITE ( $STEXT )
        ENDIF
    ENDIF
ENDFUNC
