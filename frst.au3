FUNC _WINAPI_STRLEN ( $PSTRING , $BUNICODE = TRUE )
    LOCAL $W = ""
    IF $BUNICODE THEN $W = "W"
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "int" , "lstrlen" & $W , "struct*" , $PSTRING )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
