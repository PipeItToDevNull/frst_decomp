    ENDIF
    LOCAL CONST $WM_INPUTLANGCHANGEREQUEST = 0x50
    DLLCALL ( "user32.dll" , "none" , "SendMessage" , "hwnd" , $HWND , "uint" , $WM_INPUTLANGCHANGEREQUEST , "uint" , $IFLAGS , "uint_ptr" , $HLOCALE )
