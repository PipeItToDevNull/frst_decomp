FUNC _WINAPI_SWITCHCOLOR ( $ICOLOR )
    IF $ICOLOR = + 0xffffffff THEN RETURN $ICOLOR
    RETURN BITOR ( BITAND ( $ICOLOR , 0xff00 ) , BITSHIFT ( BITAND ( $ICOLOR , 0xff ) , + 0xfffffff0 ) , BITSHIFT ( BITAND ( $ICOLOR , 0xff0000 ) , 0x10 ) )
ENDFUNC
