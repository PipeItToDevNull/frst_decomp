FUNC _WINAPI_QUERYDISKUSAGE ( $BTOOLTIP = FALSE )
    STATIC LOCAL $ICURTOTALIO = 0x0
    STATIC LOCAL $ICURTICKCOUNT = DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ]
    LOCAL $APROCESSES = PROCESSLIST ( )
    LOCAL $ITOTALIO = 0x0
    LOCAL $AIO
    FOR $I = 0x1 TO $APROCESSES [ 0x0 ] [ 0x0 ]
        IF $APROCESSES [ $I ] [ 0x0 ] = "taskmgr.exe" OR $APROCESSES [ $I ] [ 0x0 ] = "dwm.exe" THEN CONTINUELOOP
        IF $APROCESSES [ $I ] [ 0x1 ] = @AUTOITPID OR $APROCESSES [ $I ] [ 0x1 ] = 0x4 THEN CONTINUELOOP
        $AIO = PROCESSGETSTATS ( $APROCESSES [ $I ] [ 0x1 ] , 0x1 )
        IF @ERROR THEN CONTINUELOOP
        $ITOTALIO += $AIO [ 0x0 ] + $AIO [ 0x1 ] + $AIO [ 0x2 ]
    NEXT
    LOCAL $IDIFFTOTALIO = $ITOTALIO - $ICURTOTALIO
    LOCAL $IDIFFTICKCOUNT = ( DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ] - $ICURTICKCOUNT ) * 0x3e8
    $ICURTICKCOUNT = DLLCALL ( "kernel32.dll" , "uint64" , "GetTickCount64" ) [ 0x0 ]
    IF $ICURTOTALIO = 0x0 THEN
        $ICURTOTALIO = $ITOTALIO
        RETURN _WINAPI_QUERYDISKUSAGE ( FALSE )
    ENDIF
    $ICURTOTALIO = $ITOTALIO
    LOCAL $FPERCENT = ROUND ( $IDIFFTOTALIO / $IDIFFTICKCOUNT * 0x64 , 0x1 )
    IF $BTOOLTIP AND $FPERCENT > 0x0 THEN TOOLTIP ( "IO " & $FPERCENT & "%" , DEFAULT , DEFAULT , "" , 0x0 , 0x1 )
    RETURN $FPERCENT
ENDFUNC
FUNC _WINAPI_QUERYPERFORMANCECOUNTER ( )
    LOCAL $ACALL = DLLCALL ( "kernel32.dll" , "bool" , "QueryPerformanceCounter" , "int64*" , 0x0 )
    IF @ERROR OR NOT $ACALL [ 0x0 ] THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    RETURN $ACALL [ 0x1 ]
ENDFUNC
