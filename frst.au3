$ATTEN = " <==== " & $UPD1
CASE STRINGREGEXP ( $TASKNAME , "\w{8}-\w{4}-\w{4}-\w{4}-\w{12}" ) AND STRINGINSTR ( $COMPANY , "Microsoft Corp" ) AND ( STRINGREGEXP ( $FILE , "(?i)AppData\\Local\\\w+\.exe" ) OR STRINGREGEXP ( $FILE , "(?i):\\Windows\\SysWOW64\\\w+\.exe" ) )
$ATTEN = " <==== " & $UPD1
