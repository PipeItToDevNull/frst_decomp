FUNC _WINAPI_SENDINPUT ( $ITYPE , $NINPUTS , $TINPUTARRAY )
    IF ( $ITYPE < 0x0 ) OR ( $ITYPE > 0x2 ) THEN RETURN SETERROR ( 0xa , 0x0 , 0x0 )
    LOCAL $NSIZE = DLLSTRUCTGETSIZE ( $TINPUTARRAY )
    IF MOD ( $NSIZE , $NINPUTS ) THEN RETURN SETERROR ( 0xb , 0x0 , 0x0 )
    $NSIZE /= $NINPUTS
    LOCAL $TINPUT
    FOR $I = 0x1 TO $NINPUTS
        $TINPUT = DLLSTRUCTCREATE ( "dword type" , DLLSTRUCTGETPTR ( $TINPUTARRAY ) + ( $I + 0xffffffff ) * $NSIZE )
        DLLSTRUCTSETDATA ( $TINPUT , "type" , $ITYPE )
    NEXT
    LOCAL $ARESULT = DLLCALL ( "user32.dll" , "uint" , "SendInput" , "uint" , $NINPUTS , "struct*" , $TINPUTARRAY , "int" , $NSIZE )
    IF @ERROR THEN RETURN SETERROR ( @ERROR , @EXTENDED , 0x0 )
    IF $ARESULT [ 0x0 ] = 0x0 THEN RETURN SETERROR ( 0xc , _WINAPI_GETLASTERROR ( ) , 0x0 )
    IF $ARESULT [ 0x0 ] <> $NINPUTS THEN RETURN SETERROR ( 0xd , _WINAPI_GETLASTERROR ( ) , $ARESULT [ 0x0 ] )
    RETURN $ARESULT [ 0x0 ]
ENDFUNC
