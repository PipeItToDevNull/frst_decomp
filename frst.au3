    LOCAL $TCOMMAND = 0x0
    IF $SAPPNAME = "" THEN $SAPPNAME = NULL
    IF $SCOMMAND <> "" THEN
        $TCOMMAND = DLLSTRUCTCREATE ( "wchar Text[" & 0x104 + 0x1 & "]" )
