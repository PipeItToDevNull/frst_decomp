    IF ISARRAY ( $ANAMES ) THEN
        IF $SFILEPATH AND NOT _WINAPI_PATHISDIRECTORY ( $SFILEPATH ) THEN RETURN SETERROR ( @ERROR + 0x14 , @EXTENDED , 0x0 )
    ENDIF
    $PPIDL = _WINAPI_SHELLILCREATEFROMPATH ( $SFILEPATH )
