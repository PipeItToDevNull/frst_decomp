        IF $ACALL [ 0x0 ] THEN $IERROR = 0xa
    ENDIF
    IF $IOBJ THEN _WINAPI_COUNINITIALIZE ( )
    _WINAPI_COTASKMEMFREE ( $PPIDL )
    FOR $I = 0x1 TO $ICOUNT
        $PPIDL = DLLSTRUCTGETDATA ( $TPTR , $I )
        IF $PPIDL THEN
