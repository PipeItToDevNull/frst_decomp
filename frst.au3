    $AMEM [ 0x1 ] = DLLSTRUCTGETDATA ( $TMEM , 0x3 )
    $AMEM [ 0x2 ] = DLLSTRUCTGETDATA ( $TMEM , 0x4 )
    $AMEM [ 0x3 ] = DLLSTRUCTGETDATA ( $TMEM , 0x5 )
    $AMEM [ 0x4 ] = DLLSTRUCTGETDATA ( $TMEM , 0x6 )
    $AMEM [ 0x5 ] = DLLSTRUCTGETDATA ( $TMEM , 0x7 )
