$ATTEN = " <==== " & $UPD1
CASE STRINGINSTR ( $TASKNAME , "Firefox Default Browser Agent" ) AND NOT STRINGREGEXP ( $COMM , "(?i)\\Mozilla Firefox\\default-browser-agent.exe" )
$ATTEN = " <==== " & $UPD1
CASE STRINGREGEXP ( $FILE , "(?i)" & STRINGREGEXPREPLACE ( @USERPROFILEDIR , "\\" , "\\\\" ) & "\\" & $TASKNAME & "\.exe" )
$ATTEN = " <==== " & $UPD1
